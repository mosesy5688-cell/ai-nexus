{
  "name": "ai-nexus",
  "version": "2.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npm run copy:wasm && astro dev",
    "clean": "node -e \"import('fs').then(f=>f.existsSync('.astro')&&f.rmSync('.astro',{recursive:true}))\"",
    "copy:wasm": "node -e \"import('fs').then(f=>f.copyFileSync('node_modules/@journeyapps/wa-sqlite/dist/wa-sqlite-async.wasm','public/assets/sqlite/wa-sqlite-async.wasm'))\"",
    "build": "npm run copy:wasm && npm run clean && cross-env NODE_ENV=production astro build",
    "preview": "astro preview",
    "fetch-data": "node scripts/multi-source-fetcher.js",
    "fetch-data:v3": "node scripts/fetch-data-v3.js",
    "pack-db": "node scripts/factory/pack-db.js",
    "factory:bootstrap": "node scripts/factory/lib/registry-bootstrap.js",
    "factory:bootstrap:umid": "node scripts/factory/lib/registry-bootstrap.js --phase=umid-stamping",
    "factory:bootstrap:vault": "node scripts/factory/lib/registry-bootstrap.js --phase=vault-push",
    "factory:bootstrap:pack": "node scripts/factory/lib/registry-bootstrap.js --phase=initial-pack",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "ces-check": "python scripts/check_compliance.py",
    "ces": "npm run ces-check",
    "health-check": "node scripts/sentinel-prod.js",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name ai-nexus --commit-dirty=true"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.2",
    "@astrojs/sitemap": "^3.7.1",
    "@cloudflare/workers-types": "^4.20251121.0",
    "@google/generative-ai": "^0.18.0",
    "@iconify-json/mdi": "^1.1.67",
    "@journeyapps/wa-sqlite": "^1.5.0",
    "@tailwindcss/typography": "^0.5.19",
    "@xenova/transformers": "^2.17.2",
    "astro": "^6.0.5",
    "autoprefixer": "^10.4.27",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.1",
    "dotenv": "^17.2.3",
    "fuse.js": "^7.1.0",
    "fzstd": "^0.1.1",
    "glob": "^13.0.5",
    "marked": "^13.0.3",
    "minisearch": "^7.2.0",
    "mustache": "^4.2.0",
    "pako": "^2.1.0",
    "sanitize-html": "^2.17.1",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.965.0",
    "@aws-sdk/lib-storage": "^3.1037.0",
    "@dsnp/parquetjs": "^1.8.7",
    "@playwright/test": "^1.57.0",
    "@types/pako": "^2.0.4",
    "@vitest/coverage-v8": "^4.0.14",
    "@vitest/ui": "^4.0.14",
    "axios": "^1.13.2",
    "cheerio": "^1.1.2",
    "cross-env": "^10.1.0",
    "happy-dom": "^20.0.10",
    "pdf-parse": "^2.4.5",
    "vitest": "^4.0.14",
    "wrangler": "^4.74.0",
    "zstd-codec": "^0.1.5"
  }
}
