{
  "name": "@free2aitools/sdk",
  "version": "0.0.0",
  "description": "Free, public TypeScript SDK for the Free2AITools AI discovery / evidence / identity REST API. Retrieves candidates, evidence, and FNI rankings; the caller makes the final decision.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"import('fs').then(f=>f.existsSync('dist')&&f.rmSync('dist',{recursive:true}))\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run test/live-smoke.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "free2aitools",
    "ai-discovery",
    "fni",
    "model-evidence",
    "rest-sdk"
  ],
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
