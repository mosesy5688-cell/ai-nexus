{
  "name": "@free2aitools/sdk",
  "version": "0.1.0",
  "description": "Free, public TypeScript SDK for the Free2AITools AI discovery / evidence / identity REST API. Retrieves candidates, evidence, and FNI rankings; the caller makes the final decision.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mosesy5688-cell/ai-nexus.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://free2aitools.com",
  "author": "Free2AITools",
  "bugs": {
    "url": "https://github.com/mosesy5688-cell/ai-nexus/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"import('fs').then(f=>f.existsSync('dist')&&f.rmSync('dist',{recursive:true}))\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run test/live-smoke.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "free2aitools",
    "ai-discovery",
    "fni",
    "model-evidence",
    "rest-sdk"
  ],
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
