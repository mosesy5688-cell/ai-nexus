---
// src/layouts/Layout.astro
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SearchCommandPalette from '@/components/common/SearchCommandPalette.astro';
import OnboardingTour from '@/components/common/OnboardingTour.astro';
import { ViewTransitions } from 'astro:transitions';

// V9.70: Ensure global Tailwind CSS is ALWAYS included
// This import MUST be at layout level to ensure all pages get Tailwind
import '../styles/base.css';

interface Props {
	title: string;
	description?: string;
    image?: string;
    jsonld?: object;
    canonical?: string;
}

// V3.1 Phase 7: Enhanced SEO defaults
const { 
    title, 
    description = 'The Definitive Open-Source AI Index. VRAM calculator, precision tech specs, neural discovery, and actionable toolchains powered by Free2AI.', 
    image = '/og-image.jpg', 
    jsonld,
    canonical
} = Astro.props;

// V18.12.5: Extreme Edge Resilience Strategy (SWR)
// Allow Cloudflare to serve stale content for up to 7 days if origin/R2 is unstable.
if (!Astro.response.headers.has('Cache-Control')) {
    Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=604800');
}
const resolvedImage = new URL(image, Astro.site || Astro.url.origin);
const canonicalURL = canonical ? new URL(canonical, Astro.site || Astro.url.origin) : new URL(Astro.url.pathname, Astro.site || Astro.url.origin);

// V3.1 Phase 7: Schema.org Organization + WebSite with SearchAction
const defaultSchema = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "Organization",
            "name": "Free2AI",
            "url": "https://free2aitools.com",
            "logo": "https://cdn.free2aitools.com/assets/logo.png",
            "description": "The Definitive Open-Source AI Index."
        },
        {
            "@type": "WebSite",
            "name": "Free2AI",
            "url": "https://free2aitools.com",
            "potentialAction": {
                "@type": "SearchAction",
                "target": "https://free2aitools.com/search?q={search_term_string}",
                "query-input": "required name=search_term_string"
            }
        }
    ]
};
const schemaToUse = jsonld || defaultSchema;

// V23.1: Zero-JSON SSR Compliance
// Global stats are now expected to be loaded client-side or via VFS metadata shards
const siteMeta = {
    category_stats: {},
    trending: {},
    _inlined_at: new Date().toISOString()
};
---

<!doctype html>
<html lang="en">
<head>
    <!-- V19.4: Pre-inject Site Metadata to eliminate redundant HTTP hits -->
    <script is:inline define:vars={{ siteMeta }}>
        window.__SITE_META__ = siteMeta;
    </script>
    <!-- V21.16: Extreme Performance Strategy - Delayed Third-Party Scripts -->
    <script is:inline>
        window.addEventListener('load', () => {
            setTimeout(() => {
                // Google Tag Manager
                (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
                new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
                j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
                'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
                })(window,document,'script','dataLayer','GTM-58C2CQ8G');

                // Google AdSense
                const adsense = document.createElement('script');
                adsense.async = true;
                adsense.src = "https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-2292826803755214";
                adsense.crossOrigin = "anonymous";
                document.head.appendChild(adsense);
            }, 3000);
        });
    </script>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    
    <!-- V16.8.1 RSS Feeds: Standardized Daily Feed -->
    <link rel="alternate" type="application/rss+xml" title="AI Knowledge Base Feed" href="https://cdn.free2aitools.com/rss/knowledge.xml">
    <link rel="alternate" type="application/rss+xml" title="AI Industry Daily Updates Feed" href="https://cdn.free2aitools.com/rss/reports.xml">

    <!-- V4.5 Performance: Preconnect to external origins for faster FCP -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
    <link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin>
    <link rel="dns-prefetch" href="https://huggingface.co">
    <link rel="dns-prefetch" href="https://github.com">
    
    <!-- V4.6 Performance: Preload critical Alpine.js (LCP blocker) -->
    <link rel="modulepreload" href="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" as="script">
    
    <!-- Open Graph Meta Tags -->
    <meta property="og:type" content="website">
    <meta property="og:url" content={Astro.url.href}>
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:image" content={resolvedImage}>

    <!-- Twitter Card Meta Tags -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content={Astro.url.href}>
    <meta property="twitter:title" content={title}>
    <meta property="twitter:description" content={description}>
    <meta property="twitter:image" content={resolvedImage}>

    <meta name="description" content={description}>
    <title>{title}</title>

    <link rel="canonical" href={canonicalURL.href} />

    <meta property="article:published_time" content={new Date().toISOString()} />
    <meta property="article:modified_time" content={new Date().toISOString()} />

    <!-- Global Alpine.js loaded for TabbedContent & ModelCarousel -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <ViewTransitions fallback="swap" />
    
    <!-- V18.1: Extreme Prefetching & Visual Stability -->
    <style is:global>
        :root {
            --bg-canvas: #181818;
            --bg-surface: #313131;
            --border-hairline: #272727;
            --text-primary: #c2c2c2;
            --text-strong: #ffffff;
            --brand-orange: #ff6633;
        }

        html {
            font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            font-feature-settings: "cv02", "cv03", "cv04", "cv11";
            font-variant-numeric: tabular-nums;
            background-color: var(--bg-canvas);
            color: var(--text-primary);
            overflow-x: hidden;
        }

        /* V22.10: Zero Shadow Policy */
        * {
            box-shadow: none !important;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }
        
        /* Industrial Scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }

        /* Eliminate CLS via aspect-ratio containment */
        .listing-card-grid {
            content-visibility: auto;
            contain-intrinsic-size: 1px 1000px;
        }
    </style>
</head>
<body class="bg-[var(--bg-canvas)] text-[var(--text-primary)] font-sans antialiased flex flex-col min-h-screen selection:bg-zinc-500/30">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-58C2CQ8G"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    
    <script is:inline>
        // V16.9.24: Prevent FOUC by applying theme immediately
        function applyTheme() {
            document.documentElement.classList.add('dark');
            document.body.style.backgroundColor = '#181818';
        }
        applyTheme();
        
        // V22.11: Persist theme across View Transitions
        document.addEventListener('astro:after-swap', applyTheme);
    </script>
    
    <SearchCommandPalette />
    <Header />
    <OnboardingTour />
    <main class="flex-grow container mx-auto px-4 py-4 max-w-7xl">
        <slot />
    </main>
    <Footer />
</body>
</html>
