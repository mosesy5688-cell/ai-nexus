---
export const prerender = false;

// /prompt/* returns 410 Gone — the `prompt` entity type was cancelled (#2141).
// The `agent` type it pointed humans to has since been cancelled too, so the
// meta-refresh + copy now point to /tools (where LangChain/agent frameworks live
// as tools), avoiding a /prompt/*->/agents->404 chain. 410 is the correct
// permanent-removal signal for search engines.
// Reversible: restore the prior SSR detail page from git history.
Astro.response.status = 410;
Astro.response.headers.set('Cache-Control', 'public, max-age=86400');
---
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Prompt Removed — Free2AITools</title>
    <meta name="robots" content="noindex">
    <meta http-equiv="refresh" content="5;url=/tools">
    <style>
        body { font-family: system-ui, sans-serif; background: #181818; color: #e5e5e5; max-width: 640px; margin: 4rem auto; padding: 0 1.5rem; }
        a { color: #93c5fd; }
        code { background: #272727; padding: 0.1em 0.3em; border-radius: 3px; }
    </style>
</head>
<body>
    <h1>410 — Prompt Removed</h1>
    <p>The <code>/prompt</code> entity type has been permanently retired.</p>
    <p>Explore LangChain and other AI tools at <a href="/tools">/tools</a>.</p>
    <p>For programmatic access, see <a href="/llms.txt">/llms.txt</a> or <a href="/openapi.json">/openapi.json</a>.</p>
    <p style="margin-top:2rem;opacity:0.5;font-size:0.9em">Redirecting to /tools in 5 seconds…</p>
</body>
</html>
