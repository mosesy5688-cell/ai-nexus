---
// SSR Mode - Server-side rendering for stability
import Layout from '../../layouts/Layout.astro';
import { getCachedDbConnection, loadManifest, executeSql } from '../../lib/sqlite-engine';

const title = "AI Model & Tool Rankings";
const description = "Explore top-rated AI models, agents, datasets, and tools ranked by the Free2AITools Nexus Index (FNI).";

const CATEGORY_META: Record<string, { label: string; icon: string; description: string; href: string }> = {
  'text-generation': {
    label: 'Text Generation',
    icon: '💬',
    description: 'Top LLMs, code assistants, and translation systems.',
    href: '/text-generation'
  },
  'knowledge-retrieval': {
    label: 'Knowledge Retrieval',
    icon: '🔍',
    description: 'RAG, embeddings, and intelligent data analysis.',
    href: '/knowledge-retrieval'
  },
  'vision-multimedia': {
    label: 'Vision & Multimedia',
    icon: '🎨',
    description: 'Image generation, video AI, and speech processing.',
    href: '/vision-multimedia'
  },
  'automation-workflow': {
    label: 'Automation',
    icon: '⚡',
    description: 'AI agents and autonomous workflow frameworks.',
    href: '/automation-workflow'
  },
  'infrastructure-ops': {
    label: 'Infrastructure',
    icon: '🔧',
    description: 'Fine-tuning, quantization, and deployment tools.',
    href: '/infrastructure-ops'
  }
};

// V23.6: VFS-Only Category Counts (replaces CDN category_stats.json)
const env = ((Astro as any).locals.runtime)?.env || {};
const r2Bucket = env.R2_ASSETS;
const isDev = !!import.meta.env?.DEV;
const shouldSimulate = !!env.SIMULATE_PRODUCTION || (isDev && env.NODE_ENV !== 'production');

let categoryCounts: Record<string, number> = {};
try {
    await loadManifest(r2Bucket, shouldSimulate);
    const engine = await getCachedDbConnection(r2Bucket, shouldSimulate, 'meta-model-core.db');
    const rows = await executeSql(engine.sqlite3, engine.db,
        `SELECT category, COUNT(*) as count FROM entities WHERE category != '' GROUP BY category`, []);
    for (const r of rows) {
        if (r.category) categoryCounts[r.category] = r.count;
    }
} catch (e: any) {
    console.warn('[Ranking] VFS category count query failed:', e.message);
}

// V18.10.2: Explicit Edge Caching with Revalidation Guard
Astro.response.headers.set('Cache-Control', 'public, max-age=0, must-revalidate, s-maxage=60');
---

<Layout title={title} description={description}>
    <div class="py-4">
        <div class="text-center mb-12">
            <h1 class="text-4xl md:text-6xl font-black text-gray-900 dark:text-white tracking-tighter mb-4">
                AI Ecosystem Rankings
            </h1>
            <p class="text-xl text-theme-secondary max-w-2xl mx-auto font-medium">
                The Definitive High-Resolution Technical Index, driven by real-time R2 Neural Mesh data.
            </p>
        </div>

        <!-- Main Categories -->
        <div id="ranking-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
            {Object.entries(CATEGORY_META).map(([key, meta]) => (
                <a href={meta.href} class="group relative p-8 rounded-[2rem] bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 hover:shadow-2xl transition-all duration-500 overflow-hidden flex flex-col glass-effect">
                    <div class="absolute top-0 right-0 p-6 opacity-5 group-hover:opacity-10 transition-opacity">
                         <span class="text-8xl">{meta.icon}</span>
                    </div>
                    <div class="relative z-10">
                        <div class="text-4xl mb-6">{meta.icon}</div>
                        <h2 class="text-2xl font-black text-theme-primary mb-3">{meta.label}</h2>
                        <p class="text-theme-secondary mb-8 flex-grow">{meta.description}</p>

                        <div class="flex items-center justify-between mt-auto">
                            <span class="inline-flex items-center text-blue-600 dark:text-blue-400 font-bold group-hover:gap-2 transition-all">
                                View Technical Index <span class="ml-1">&rarr;</span>
                            </span>
                            <span class="text-xs font-bold px-3 py-1.5 bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-full border border-blue-100/50 dark:border-blue-500/20">
                                {categoryCounts[key] ? `${categoryCounts[key].toLocaleString()} Models` : 'Explore'}
                            </span>
                        </div>
                    </div>
                </a>
            ))}
        </div>

        <!-- Specialized Lists (Unified Links) -->
        <div class="bg-gradient-to-br from-indigo-900 to-blue-900 rounded-[3rem] p-10 md:p-16 text-white shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -mr-32 -mt-32 blur-3xl"></div>
            <div class="relative z-10">
                <h2 class="text-3xl font-black mb-10 text-center tracking-tight">Specialized Technical Sub-Indices</h2>
                <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8">
                    <a href="/text-generation" class="p-6 rounded-2xl bg-white/10 hover:bg-white/20 border border-white/10 backdrop-blur-md transition-all hover:-translate-y-1 text-center group">
                        <span class="block text-3xl mb-3 group-hover:scale-110 transition-transform">💬</span>
                        <span class="font-bold tracking-wide uppercase text-xs opacity-80 decoration-2">Text Gen</span>
                    </a>
                    <a href="/vision-multimedia" class="p-6 rounded-2xl bg-white/10 hover:bg-white/20 border border-white/10 backdrop-blur-md transition-all hover:-translate-y-1 text-center group">
                        <span class="block text-3xl mb-3 group-hover:scale-110 transition-transform">🎨</span>
                        <span class="font-bold tracking-wide uppercase text-xs opacity-80 decoration-2">Vision</span>
                    </a>
                    <a href="/knowledge-retrieval" class="p-6 rounded-2xl bg-white/10 hover:bg-white/20 border border-white/10 backdrop-blur-md transition-all hover:-translate-y-1 text-center group">
                        <span class="block text-3xl mb-3 group-hover:scale-110 transition-transform">🔍</span>
                        <span class="font-bold tracking-wide uppercase text-xs opacity-80 decoration-2">Neural RAG</span>
                    </a>
                    <a href="/infrastructure-ops" class="p-6 rounded-2xl bg-white/10 hover:bg-white/20 border border-white/10 backdrop-blur-md transition-all hover:-translate-y-1 text-center group">
                        <span class="block text-3xl mb-3 group-hover:scale-110 transition-transform">🔧</span>
                        <span class="font-bold tracking-wide uppercase text-xs opacity-80 decoration-2">Infra Ops</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</Layout>
