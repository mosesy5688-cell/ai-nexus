---
import Layout from '@/layouts/Layout.astro';
import { marked } from 'marked';
import { getRouteFromId } from '@/utils/mesh-routing-core';
import { getCachedDbConnection, loadManifest, executeSql } from '@/lib/sqlite-engine';
import { env } from 'cloudflare:workers';

const { slug } = Astro.params;
const slugStr = Array.isArray(slug) ? slug.join('/') : (slug || '');
const reportSlug = slugStr.replace(/^daily\//, '');

let report: any = null;
let reportDataSource = '404';

const r2Bucket = env?.R2_ASSETS;
const shouldSimulate = !!import.meta.env?.DEV;

// 1. Load metadata from meta-report.db
try {
    await loadManifest(r2Bucket, shouldSimulate);
    const engine = await getCachedDbConnection(r2Bucket, shouldSimulate, 'meta-report.db');
    const rows = await executeSql(engine.sqlite3, engine.db,
        `SELECT * FROM articles WHERE slug = ? OR id = ? OR id LIKE ? LIMIT 1`,
        [reportSlug, reportSlug, `%${reportSlug}%`]);
    if (rows.length > 0) {
        report = rows[0];
        reportDataSource = 'meta-report';
    }
} catch (e: any) {
    console.warn(`[Report] meta-report.db query failed: ${e?.message}`);
}

// 2. Load full content from R2/CDN
if (report) {
    const contentKey = `cache/reports/daily/${reportSlug}.json.zst`;
    try {
        let fullReport: any = null;
        if (r2Bucket && !shouldSimulate) {
            const obj = await r2Bucket.get(contentKey);
            if (obj) {
                const buf = await obj.arrayBuffer();
                const { decompress } = await import('fzstd');
                const json = new TextDecoder().decode(decompress(new Uint8Array(buf)));
                fullReport = JSON.parse(json);
            }
        }
        if (!fullReport) {
            const res = await fetch(`https://cdn.free2aitools.com/${contentKey}`);
            if (res.ok) {
                const buf = await res.arrayBuffer();
                const { decompress } = await import('fzstd');
                const json = new TextDecoder().decode(decompress(new Uint8Array(buf)));
                fullReport = JSON.parse(json);
            }
        }
        if (fullReport) {
            report = { ...report, ...fullReport };
            reportDataSource = 'meta-report+content';
        }
    } catch (e: any) {
        console.warn(`[Report] Content load failed for ${reportSlug}: ${e?.message}`);
    }
}

Astro.response.headers.set('X-Data-Source', reportDataSource);
Astro.response.headers.set('Cache-Control', 'public, max-age=60, s-maxage=3600');

const pageTitle = report?.title || `AI Daily Report - ${reportSlug}`;
const pageDescription = (report?.summary || report?.subtitle || '').substring(0, 160);
const contentHtml = report?.content ? marked.parse(report.content) : '';
---

<Layout title={pageTitle} description={pageDescription} canonical={`/reports/${reportSlug}`}>
  <div class="container mx-auto px-4 py-12">
    {!report ? (
      <div class="py-24 text-center max-w-2xl mx-auto">
        <div class="text-4xl mb-6">📡</div>
        <h1 class="text-xl font-bold text-[var(--text-strong)] mb-2 uppercase">Report Not Found</h1>
        <p class="text-xs text-zinc-400 mb-8">The report for {reportSlug} is not yet available.</p>
        <a href="/reports" class="text-xs font-bold text-indigo-400 hover:text-indigo-300 uppercase tracking-widest">← All Reports</a>
      </div>
    ) : (
      <article class="prose dark:prose-invert max-w-4xl mx-auto">
        <header class="mb-8 not-prose">
          <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest mb-2">{(report.published_at || reportSlug).substring(0, 10)}</p>
          <h1 class="text-2xl md:text-3xl font-black text-[var(--text-strong)] tracking-tight">{report.title}</h1>
          {report.subtitle && <p class="text-base text-zinc-400 mt-2">{report.subtitle}</p>}
        </header>
        {contentHtml ? (
          <Fragment set:html={contentHtml} />
        ) : report.highlights?.length > 0 ? (
          <div class="space-y-12 not-prose">
            {report.highlights.map((item: any) => (
              <div class="group border-b border-zinc-800 pb-10 last:border-0">
                <div class="flex items-center gap-3 mb-4">
                  <span class="px-2 py-0.5 text-[10px] font-black bg-indigo-500 text-white rounded uppercase tracking-widest">
                    {item.type || 'Highlight'}
                  </span>
                  {item.fni_score && (
                    <span class="text-[10px] font-bold text-emerald-500">FNI: {Math.round(item.fni_score)}</span>
                  )}
                </div>
                <h2 class="text-3xl font-black text-white mb-4 tracking-tight group-hover:text-indigo-400 transition-colors">
                  <a href={getRouteFromId(item.id, item.type)}>{item.name || item.id}</a>
                </h2>
                <p class="text-lg text-zinc-400 leading-relaxed mb-6">
                  {item.description || item.summary || 'Details available on the entity page.'}
                </p>
              </div>
            ))}
          </div>
        ) : (
          <p class="text-zinc-500">No detailed content available for this report.</p>
        )}
      </article>
    )}
  </div>
</Layout>
