---
/**
 * Reports Index — V25.1 News-Style Title List
 * Minimal SSR: single fetch from index.json.gz → title + date list
 * No DailyTrendingSection, TrendChart, or per-day fallback scanning.
 */
import Layout from '@/layouts/Layout.astro';
import { getRouteFromId } from '@/utils/mesh-routing-core';

const CDN_BASE = 'https://cdn.free2aitools.com';
const env = (Astro as any).locals?.runtime?.env;
const R2_FILES = env?.R2_FILES;

let reports: any[] = [];

if (R2_FILES) {
    // V25.3: Real-time Discovery via R2.list()
    try {
        const list = await R2_FILES.list({ prefix: 'cache/reports/daily/' });
        reports = list.objects
            .filter((obj: any) => obj.key.endsWith('.json.gz') || obj.key.endsWith('.json'))
            .map((obj: any) => {
                const filename = obj.key.split('/').pop()!;
                const dateStr = filename.split('.')[0];
                return {
                    id: dateStr,
                    title: `AI Daily Digest - ${dateStr}`, // Discovery-time title
                    date: dateStr,
                    lastModified: obj.uploaded
                };
            })
            .sort((a: any, b: any) => b.date.localeCompare(a.date));
    } catch (e) {
        console.error('[Reports] R2.list failed:', (e as Error).message);
    }
}

const pageTitle = "AI Industry Daily Reports";
const pageDescription = "Stay updated with the latest trends, breakthroughs, and popular models in the open-source AI landscape.";

// V25.3: Atomic Edge Caching (60s) to balance freshness and R2 Operations cost
Astro.response.headers.set('Cache-Control', reports.length > 0
    ? 'public, max-age=60, s-maxage=60'
    : 'public, max-age=0, s-maxage=0');
---

<Layout title={pageTitle} description={pageDescription}>
  <div class="container mx-auto px-4 py-16 max-w-3xl">
    <header class="mb-12">
      <h1 class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-[var(--text-strong)] tracking-tight mb-3 uppercase">
        Intelligence Reports
      </h1>
      <p class="text-base text-zinc-500 dark:text-zinc-400 font-medium leading-normal">
        Daily technical briefings from the AI ecosystem.
      </p>
    </header>

    {reports.length > 0 ? (
      <div class="border border-[var(--border-hairline)] bg-[var(--bg-surface)] rounded-sm overflow-hidden">
        <div class="p-4 border-b border-[var(--border-hairline)] bg-black/40 flex items-center justify-between">
          <h2 class="text-xs font-bold text-[var(--text-strong)] uppercase tracking-widest">Archive</h2>
          <span class="text-[9px] font-bold text-zinc-500 uppercase tracking-widest">{reports.length} Reports</span>
        </div>
        <ul class="divide-y divide-[var(--border-hairline)]">
          {reports.map((report) => (
            <li class="group transition-colors hover:bg-black/20">
              <a href={getRouteFromId(report.id, 'report')} class="flex items-center p-4 gap-6">
                <span class="flex-shrink-0 w-28 text-[10px] font-bold tabular-nums text-zinc-500 tracking-widest group-hover:text-indigo-400 transition-colors">
                  {new Date(report.date).toISOString().split('T')[0]}
                </span>
                <h3 class="flex-1 min-w-0 text-sm font-bold text-[var(--text-strong)] truncate group-hover:text-[#bdc3ff] transition-colors">
                  {report.title}
                </h3>
                <span class="flex-shrink-0 text-[#bdc3ff] text-xs opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all">
                  &rarr;
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ) : (
      <div class="py-24 text-center">
        <div class="text-4xl mb-6">📡</div>
        <p class="text-zinc-500 dark:text-zinc-400 font-medium uppercase tracking-widest text-xs">
          Neural Mesh Synchronizing... No daily reports available.
        </p>
      </div>
    )}
  </div>
</Layout>
