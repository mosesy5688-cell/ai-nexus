---
/**
 * AI Tools Catalog (V4.1)
 * Optimized SSR + UniversalCatalog Engine
 */
import Layout from '../layouts/Layout.astro';
import ListingControls from '../components/common/ListingControls.astro';
import { fetchCatalogData, truncateListingItem } from '../utils/catalog-fetcher.js';
import CatalogCard from '../components/common/CatalogCard.astro';

// SSR Data Fetching
const { items: allTools = [], totalPages, totalEntities } = await fetchCatalogData('tool', (Astro as any).locals.runtime);
const tools = allTools.slice(0, 48).map(truncateListingItem);

const pageTitle = "AI Tools & Utilities Catalog | Free2AI";
const pageDescription = "Discover the best open-source AI tools, libraries, and utilities for developers and researchers.";

// V24.9: Only edge-cache pages with data; prevent caching empty/error states
Astro.response.headers.set('Cache-Control', tools.length > 0
    ? 'public, max-age=0, must-revalidate, s-maxage=60'
    : 'public, max-age=0, s-maxage=0');
---

<Layout title={pageTitle} description={pageDescription}>
    <main class="min-h-screen py-4">
        <header class="mb-8 border-b border-[var(--border-hairline)] pb-6">
            <div class="flex items-center gap-2 mb-2">
                <span class="text-[10px] font-black text-zinc-500 uppercase tracking-[0.3em]">Utility Node v25.1</span>
                <span class="w-1 h-1 bg-indigo-500 rounded-full"></span>
                <span class="text-[10px] font-black text-indigo-500 uppercase tracking-widest">Industrial SDKs</span>
            </div>
            <h1 class="text-2xl md:text-3xl font-black text-gray-900 dark:text-[var(--text-strong)] mb-4 tracking-tight uppercase">
                AI Tools <span class="text-zinc-500">Utilities</span>
            </h1>
            <p class="text-sm text-gray-600 dark:text-zinc-400 max-w-2xl leading-relaxed tracking-tight">
                High-resolution catalog of neural frameworks and software kits. Professional utilities for researchers and core developers.
            </p>
        </header>

        <ListingControls type="tool" searchId="tools-search" />

        <div id="tools-catalog-grid" class="flex flex-col gap-1">
            {tools.map((tool: any) => (
                <div class="animate-in fade-in slide-in-from-bottom-2 duration-300">
                    <CatalogCard item={tool} type="tool" />
                </div>
            ))}
        </div>

        <div id="pagination" class="mt-16 flex justify-center items-center gap-4"></div>
    </main>

    <script define:vars={{ initialData: tools, totalPages, totalEntities }}>
        window.__CATALOG_DATA__ = {
            items: initialData,
            totalPages,
            totalEntities
        };
    </script>

    <script>
        import { UniversalCatalog } from '../scripts/lib/UniversalCatalog.js';
        
        const init = () => {
            new UniversalCatalog({
                initialData: window.__CATALOG_DATA__?.items || [],
                totalPages: window.__CATALOG_DATA__?.totalPages || 1,
                totalEntities: window.__CATALOG_DATA__?.totalEntities || 0,
                type: 'tool',
                gridId: 'tools-catalog-grid',
                searchId: 'tools-search',
            });
        };

        document.addEventListener('astro:page-load', init);
    </script>
</Layout>
