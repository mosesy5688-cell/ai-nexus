---
export const prerender = false;

// /space/* returns 410 Gone — the `space` entity type was merged into `model`.
// A space demos a model, so the demo signal belongs on that model; there is no
// stable 1:1 per-space target to redirect to, so 410 (permanent removal) is the
// honest signal for search engines. Humans get a meta-refresh to /models.
// Reversible: restore the prior SSR detail page from git history.
Astro.response.status = 410;
Astro.response.headers.set('Cache-Control', 'public, max-age=86400');
---
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>Space Removed — Free2AITools</title>
    <meta name="robots" content="noindex">
    <meta http-equiv="refresh" content="5;url=/models">
    <style>
        body { font-family: system-ui, sans-serif; background: #181818; color: #e5e5e5; max-width: 640px; margin: 4rem auto; padding: 0 1.5rem; }
        a { color: #93c5fd; }
        code { background: #272727; padding: 0.1em 0.3em; border-radius: 3px; }
    </style>
</head>
<body>
    <h1>410 — Space Removed</h1>
    <p>The <code>/space</code> entity type has been merged into <code>/model</code> (a space demos a model).</p>
    <p>Explore AI models at <a href="/models">/models</a>.</p>
    <p>For programmatic access, see <a href="/llms.txt">/llms.txt</a> or <a href="/openapi.json">/openapi.json</a>.</p>
    <p style="margin-top:2rem;opacity:0.5;font-size:0.9em">Redirecting to /models in 5 seconds…</p>
</body>
</html>
