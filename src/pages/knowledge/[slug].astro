---
/**
 * Knowledge Base Article Template
 * V16.2 - CDN Enhanced with mesh integration
 */

export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import KnowledgeHeader from '../../components/knowledge/KnowledgeHeader.astro';
import KnowledgeContent from '../../components/knowledge/KnowledgeContent.astro';
import KnowledgeSidebar from '../../components/knowledge/KnowledgeSidebar.astro';
import KnowledgeRelated from '../../components/knowledge/KnowledgeRelated.astro';
import KnowledgeGroundedEntities from '../../components/knowledge/KnowledgeGroundedEntities.astro';
import ReadStatusManager from '../../components/knowledge/ReadStatusManager.astro';
import { articles } from '../../data/knowledge-articles';
import { getArticleBySlug, getCategoryById } from '../../data/knowledge-base-config';
import { getRouteFromId, getTypeFromId } from '../../utils/mesh-routing-core.js';
import { loadEntityStreams } from '../../utils/packet-loader.js';
import { hydrateEntity } from '../../utils/entity-cache-reader-core.js';

// Load styles
import '../../styles/knowledge.css';

// Get article slug
const { slug } = Astro.params;

let article = null;
let cdnStats = null;
let knowledgeDataSource = '404';

// V26.3: VFS-First Loading (Zero JSON Mandate)
try {
    const { entity, _meta } = await loadEntityStreams('knowledge', slug || '', Astro.locals);
    if (entity) {
        const hydrated = hydrateEntity(entity, 'knowledge');
        article = {
            title: hydrated.name || hydrated.title || slug,
            description: hydrated.description || hydrated.summary || 'Article details in progress...',
            category: hydrated.category || 'fundamentals',
            content: hydrated.body_content || hydrated.content || '',
            difficulty: hydrated.difficulty || 'Intermediate',
            effort: hydrated.effort || '5 min',
            slug: slug
        };
        knowledgeDataSource = _meta.dataSource || 'vfs-primary';
    }
} catch (e) {
    console.warn(`[Knowledge] VFS loader failed for ${slug}:`, e.message);
}

// Fallback: Static content (build-time .md + config)
if (!article) {
    const configResult = getArticleBySlug(slug || '');
    const canonicalSlug = configResult?.article.slug || slug || '';
    const contentData = articles[canonicalSlug];

    if (contentData || configResult) {
        article = {
            ...(configResult?.article || {}),
            title: contentData?.title || configResult?.article.title || slug,
            description: contentData?.description || configResult?.article.description || 'Article details in progress...',
            category: configResult?.category.id || contentData?.category || 'fundamentals',
            content: contentData?.content || `## ${contentData?.title || configResult?.article.title || slug}\n\nInformation about this topic is currently being aggregated in the Knowledge Mesh.\n\n### Related Concepts\n- [Knowledge Hub](/knowledge)`,
            difficulty: configResult?.article.difficulty || contentData?.difficulty || 'Intermediate',
            effort: configResult?.article.effort || contentData?.effort || '5 min',
            slug: slug
        };
        knowledgeDataSource = 'static-fallback';
    } else {
        const cat = getCategoryById(slug);
        if (cat) {
            article = {
                title: cat.title,
                description: cat.description,
                category: cat.id,
                content: `## ${cat.title}\n\n${cat.description}\n\n### Articles in this Category\n` +
                         cat.articles.map(a => `- [${a.title}](/knowledge/${a.slug})`).join('\n'),
                difficulty: 'Beginner',
                effort: 'Diverse',
                slug: slug
            };
            knowledgeDataSource = 'static-fallback';
        }
    }
}

Astro.response.headers.set('X-Data-Source', knowledgeDataSource);

const pageTitle = article ? `${article.title} - AI Knowledge Base` : 'Article Not Found';
const pageDescription = article?.description 
  ? `${article.description}${cdnStats?.refs ? ` (Referenced by ${cdnStats.refs} models/papers)` : ''}`
  : 'This article was not found.';

// Related articles (same category)
const relatedArticles = article ? Object.entries(articles)
  .filter(([key, a]) => {
     const conf = getArticleBySlug(key);
     return conf?.category.id === article?.category && key !== slug;
  })
  .slice(0, 3) : [];

// FETCH LINKED ENTITIES (Mesh Integration)
import { getMeshProfile } from '../../utils/mesh-orchestrator';
const meshId = article ? `knowledge--${article.slug}` : `knowledge--${slug}`;

let meshTiers = null;
try {
  // V21.5: Pass article metadata to enable structural injections
  const profile = await getMeshProfile(Astro.locals, meshId, article, { type: 'knowledge' });
  meshTiers = profile.tiers;
} catch (e) {
  console.error('[KnowledgeMesh] Orchestration failed:', e);
}

import NeuralGraphExplorer from '../../components/NeuralGraphExplorer.astro';
---

<Layout title={pageTitle} description={pageDescription} canonical={`/knowledge/${canonicalSlug}`}>
  <div class="article-container">
    {article ? (
      <>
        <KnowledgeHeader 
          title={article.title} 
          description={article.description} 
          category={article.category} 
          difficulty={article.difficulty}
          effort={article.effort}
          refs={cdnStats?.refs || 0}
        />

        <KnowledgeContent content={article.content} />

        <div class="mt-16 pt-12 border-t border-[var(--border-hairline)]">
          <h2 class="text-[10px] font-black text-zinc-500 uppercase tracking-widest mb-8 flex items-center gap-2">
            <span>🕸️</span> Knowledge Mesh Network
          </h2>
          <div class="rounded-sm border border-[var(--border-hairline)] bg-[var(--bg-surface)] overflow-hidden" id="mesh-hydration-root">
            <NeuralGraphExplorer currentModelId={meshId} meshTiers={meshTiers} type="concept" />
          </div>
        </div>

        {/* Linked Entities (Tabular View) - V16.2 Extracted */}
        <KnowledgeGroundedEntities meshTiers={meshTiers} />

        {relatedArticles.length > 0 && (
          <KnowledgeRelated articles={relatedArticles} />
        )}

        <KnowledgeSidebar slug={slug || ''} />

        <!-- Progress Tracking & CTA - V16.2 Extracted -->
        <ReadStatusManager slug={slug || ''} />
      </>
    ) : (
      <div class="min-h-[60vh] flex flex-col items-center justify-center text-center">
        <div class="text-6xl mb-6">🔍</div>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Article Not Found</h1>
        <p class="text-gray-600 dark:text-gray-400 mb-8 max-w-md">The article you're looking for doesn't exist or has been moved.</p>
        <a href="/knowledge" class="px-8 py-3 bg-indigo-600 text-white font-bold rounded-2xl shadow-lg">Back to Knowledge Base</a>
      </div>
    )}
  </div>
</Layout>
