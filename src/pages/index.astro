---
// src/pages/index.astro
// Constitution V5.1.2 Entity-First Architecture - Homepage (Refactored)
// V10.0: UX Strategy V2.0 Entry Layer - Simplified navigation

// Core imports
import Layout from '../layouts/Layout.astro';

// Components
import HomeTechnicalHeader from '../components/home/HomeTechnicalHeader.astro';
import HomeDailyBanner from '../components/home/HomeDailyBanner.astro';
import HomeSkeleton from '../components/home/HomeSkeleton.astro';
import HomeCategoryGrid from '../components/home/HomeCategoryGrid.astro';
import CatalogCard from '../components/common/CatalogCard.astro';
import { fetchCatalogData } from '../utils/catalog-fetcher.js';

// V4.3.2 Constitution Core Requirements
import { buildIndexSEO } from '../utils/seo-schema.js';

// URL parameters
const url = Astro.url;
const initialQuery = url.searchParams.get('q') || '';
const initialTag = url.searchParams.get('tag') || '';

// SEO - Constitution Required
const pageTitle = "Free AI Tools – The Open-Source AI Registry";
const pageDescription = "Discover and rank open-source AI models, datasets, papers, and tools. Updated daily, scored by FNI. API and MCP Server available.";

// Build JSON-LD (Constitution SEO requirement)
const seoSchema = buildIndexSEO();

// V16.5: Fetch Tier 1 SSR Data (Trending) - Using Optimized Unified Fetcher
// V18.2.5: Emergency Protection - Graceful degradation if R2 is saturated by CI
let hotModels = [];
try {
    const { items: hotItems = [] } = await fetchCatalogData('model');
    hotModels = hotItems.slice(0, 12);
} catch (e) {
    console.error('[Homepage] Critical SSR Fetch Failure:', e.message);
}

// V18.10.2: Explicit Edge Caching with Revalidation Guard
Astro.response.headers.set('Cache-Control', 'public, max-age=0, must-revalidate, s-maxage=3600, stale-while-revalidate=604800');
const { searchParams } = Astro.url;
---

<Layout title={pageTitle} description={pageDescription} jsonld={seoSchema}>

    <div 
        id="home-container" 
        data-initial-query={initialQuery} 
        data-initial-tag={initialTag}
    >
        <HomeTechnicalHeader initialQuery={initialQuery} />
        
        <HomeDailyBanner />

        <!-- V9.0: Search Results Grid (appears immediately after search) -->
        <div id="models-grid" class="flex flex-col gap-1 hidden mb-8 mt-8">
            <!-- Populated by search.js -->
        </div>
        <div id="no-results" class="text-center py-12 hidden">
            <p class="text-2xl font-semibold text-gray-700 dark:text-gray-200">No models found.</p>
            <p class="text-gray-500 dark:text-gray-400 mt-2">Try a different search term.</p>
        </div>

        <HomeCategoryGrid />

        <!-- Static Content Container (hide when searching) -->
        <div id="static-content-container" class="hide-on-search">
            
            <!-- V13: Top Picks Section (FNI-ranked) -->
            <section class="mb-4 px-4 md:px-0">
                <div class="flex flex-col items-center mb-4">
                    <div class="inline-flex items-center gap-2 mb-1">
                        <div class="w-1.5 h-1.5 rounded-full bg-amber-500/50 shadow-none"></div>
                        <h2 class="text-lg md:text-xl font-bold text-zinc-900 dark:text-[var(--text-strong)] uppercase tracking-tight">Top Picks</h2>
                        <div class="w-1.5 h-1.5 rounded-full bg-amber-500/50 shadow-none"></div>
                    </div>
                    <div class="font-bold text-[9px] text-zinc-500 dark:text-zinc-600 uppercase tracking-[0.15em] flex items-center gap-2">
                        <span class="w-4 h-px bg-zinc-200 dark:bg-zinc-800"></span>
                        Precision Intelligence • Ranked by FNI
                        <span class="w-4 h-px bg-zinc-200 dark:bg-zinc-800"></span>
                    </div>
                </div>
                
                <!-- Loading State with Skeletons (Hidden if SSR data exists) -->
                <div id="hot-models-loading" class={`glass-effect rounded-sm p-4 border border-gray-100 dark:border-gray-800 bg-white/30 dark:bg-gray-900/30 ${hotModels.length > 0 ? 'hidden' : ''}`}>
                    <HomeSkeleton count={12} />
                </div>
                
                <!-- Error State -->
                <div id="hot-models-error" class="hidden bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-6" role="alert">
                    <strong class="font-bold">Error:</strong>
                    <span class="block sm:inline" id="hot-models-error-msg"></span>
                </div>
                
                <!-- Top Picks Grid (FNI-sorted models) -->
                <div id="hot-models-grid" class={`flex flex-col gap-1 ${hotModels.length > 0 ? '' : 'hidden'}`}>
                    {hotModels.length > 0 && hotModels.map((model) => (
                        <CatalogCard item={model} type="model" isRisingStar={model.is_rising_star} />
                    ))}
                </div>

                <!-- Ecosystem Pulse placeholder removed per V21.16 performance pivot -->

                <!-- V16.2: Link to Ranking Hub -->
                <div class="mt-8 text-center">
                    <a href="/ranking" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-sm bg-zinc-800 hover:bg-zinc-700 text-white font-black transition-all shadow-none uppercase tracking-widest text-[10px]">
                        View Technical Index <span>→</span>
                    </a>
                </div>
            </section>
        </div>

        <!-- V9.0: Search results moved above Category section for better visibility -->
    </div>

    <script>
        import { loadHotModels, loadDailyReport } from '../scripts/home-client.js';

        document.addEventListener('DOMContentLoaded', () => {
            // V19.4: Hydrate dynamic components if SSR was bypassed
            loadHotModels();

            // V4.9.1 Step 2.3: Load Daily Report Banner
            loadDailyReport();
        });
    </script>
</Layout>
