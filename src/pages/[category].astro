---
/**
 * [category].astro
 * V16.9.23 Unified Category Navigation
 * Standardized for all 6 entity types (Models, Agents, Datasets, Papers, Spaces, Tools).
 * Constitution V16.2 Knowledge Mesh Compliance.
 */

import Layout from '../layouts/Layout.astro';
import ListingControls from '../components/common/ListingControls.astro';
import CatalogCard from '../components/common/CatalogCard.astro';
import { fetchCatalogData, truncateListingItem } from '../utils/catalog-fetcher.js';
import { CATEGORY_METADATA } from '../utils/category-mapping.js';

const { category: rawCategory } = Astro.params;

// V18.12.5.10: Route Guard - Prevent collision with system routes
const RESERVED_ROUTES = ['models', 'ranking', 'agents', 'spaces', 'datasets', 'papers', 'tools', 'search', 'about', 'compliance'];
if (RESERVED_ROUTES.includes(rawCategory!)) {
    return Astro.redirect('/404?source=routing-clash&id=' + rawCategory);
}

// V55.9: Legacy category alias redirect — map common names to V6 slugs
const CATEGORY_ALIASES: Record<string, string> = {
    'image-generation': 'vision-multimedia', 'image': 'vision-multimedia', 'audio': 'vision-multimedia',
    'video': 'vision-multimedia', 'multimodal': 'vision-multimedia', 'speech': 'vision-multimedia',
    'nlp': 'text-generation', 'llm': 'text-generation', 'chatbot': 'text-generation',
    'rag': 'knowledge-retrieval', 'embeddings': 'knowledge-retrieval', 'search': 'knowledge-retrieval',
    'agents': 'automation-workflow', 'robotics': 'automation-workflow',
    'quantization': 'infrastructure-ops', 'deployment': 'infrastructure-ops',
};
const category = CATEGORY_ALIASES[rawCategory!] || rawCategory!;
if (category !== rawCategory) return Astro.redirect(`/${category}`, 301);

// GR-01 (D-183 §D): soft-404 fix. Validate the resolved one-segment slug against
// the AUTHORITATIVE category set — the keys of CATEGORY_METADATA
// (src/utils/category-mapping.js), the same map this page renders from. An
// unknown slug is NOT a real category: it must be a REAL 404, emitted BEFORE any
// archive/VFS read (fetchCatalogData), served noindex with NO fabricated archive
// canonical/meta. This replaces the prior `|| {fabricated meta}` soft-200 archive.
const isKnownCategory = Object.prototype.hasOwnProperty.call(CATEGORY_METADATA, category!);

if (!isKnownCategory) {
    Astro.response.status = 404;
    Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow');
    Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=300');
}

const meta = isKnownCategory ? CATEGORY_METADATA[category!] : null;

// V16.9.23: Use unified fetcher for fallback and multi-type support.
// Guarded: an unknown slug never reads archive data (no VFS/R2 work for a 404).
const { items: rawItems = [] } = isKnownCategory
    ? await fetchCatalogData(category)
    : { items: [] };
const items = (rawItems || []).slice(0, 100).map(truncateListingItem).filter(Boolean);

const pageTitle = isKnownCategory
    ? `${meta.label} - AI Technical Index | Free2AI`
    : 'Page Not Found | Free2AI';
const pageDescription = isKnownCategory
    ? `Discover and FNI-rank ${meta.label} AI models, agents, tools and research. Updated daily.`
    : "The category you're looking for doesn't exist.";

// V24.9: Only edge-cache pages with data; prevent caching empty/error states.
// (The unknown-slug 404 Cache-Control was set above; never overwrite it here.)
if (isKnownCategory) {
    Astro.response.headers.set('Cache-Control', items.length > 0
        ? 'public, max-age=0, must-revalidate, s-maxage=3600, stale-while-revalidate=604800'
        : 'public, max-age=0, s-maxage=30');
}
---

<Layout title={pageTitle} description={pageDescription} noindex={!isKnownCategory}>
    {!isKnownCategory ? (
    <main class="min-h-screen py-4">
        <div class="container mx-auto px-4 py-12">
            <div class="max-w-4xl mx-auto text-center">
                <h1 class="text-6xl font-bold text-gray-900 dark:text-white mb-4">404</h1>
                <h2 class="text-2xl font-semibold text-gray-700 dark:text-gray-300 mb-6">Category Not Found</h2>
                <p class="text-gray-600 dark:text-gray-400 mb-8">
                    There is no category at this address. Try searching the catalog or browse from the homepage.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="/" class="inline-flex items-center justify-center px-8 py-3 text-base font-bold text-white bg-indigo-600 rounded-xl hover:bg-indigo-700 transition-all">
                        Go Home
                    </a>
                    <a href="/search" data-astro-reload class="inline-flex items-center justify-center px-8 py-3 text-base font-bold text-gray-700 bg-white border-2 border-gray-100 rounded-xl hover:bg-indigo-50/30 transition-all dark:bg-gray-800 dark:text-gray-200 dark:border-gray-700 dark:hover:bg-gray-700">
                        Search Database
                    </a>
                </div>
            </div>
        </div>
    </main>
    ) : (
    <>
    <main class="min-h-screen py-4">
        <header class="mb-12 border-b border-[var(--border-hairline)] pb-8">
            <div class="flex items-center gap-4 mb-4">
                <span class="text-6xl grayscale brightness-150">{meta.icon}</span>
                <div>
                    <div class="flex items-center gap-2 mb-2">
                        <span class="text-[10px] font-black text-zinc-500 uppercase tracking-[0.3em]">{category} Hub</span>
                        <span class="w-1 h-1 bg-indigo-500 rounded-full"></span>
                        <span class="text-[10px] font-black text-indigo-500 uppercase tracking-widest">Industrial Index</span>
                    </div>
                    <h1 class="text-3xl md:text-5xl font-black text-gray-900 dark:text-white tracking-tighter uppercase mb-2">
                        {meta.label} <span class="text-zinc-500">Archive</span>
                    </h1>
                </div>
            </div>
            <p class="text-sm text-gray-600 dark:text-zinc-400 max-w-2xl leading-relaxed tracking-tight">
                The authoritative directory of {meta.label.toLowerCase()} intelligence. Sharded across models, agents, datasets, and research nodes.
            </p>
        </header>

        <ListingControls type="all" searchId="category-search" categoryFilterId="category-filter" />

        <div id="category-grid" class="flex flex-col gap-1">
            {items.map((item: any) => (
                <div class="animate-in fade-in slide-in-from-bottom-2 duration-300">
                    <CatalogCard item={item} type={item.type || 'model'} />
                </div>
            ))}
        </div>

        <div id="pagination" class="mt-16 flex justify-center items-center gap-4"></div>
    </main>

    <script define:vars={{ initialData: items, category }}>
        window.__CATALOG_DATA__ = initialData;
        window.__CATEGORY_FILTER__ = category;
    </script>
    </>
    )}

    <script>
        import { UniversalCatalog } from '../scripts/lib/UniversalCatalog.js';

        // GR-01: this module script is hoisted and runs on every render, including
        // the unknown-slug 404 branch (which renders no #category-grid). Bail out
        // when the grid is absent so the 404 page never boots the catalog island.
        const run = () => document.getElementById('category-grid') && new UniversalCatalog({
            initialData: window.__CATALOG_DATA__ || [],
            type: 'all',
            categoryFilter: window.__CATEGORY_FILTER__ || '',
            gridId: 'category-grid',
            searchId: 'category-search',
            categoryFilterId: 'category-filter'
        });

        // Defer catalog init to idle time so it doesn't create a long task during TTI window.
        // timeout:2000 ensures it fires within 2s even on a busy main thread.
        const init = () => 'requestIdleCallback' in window
            ? requestIdleCallback(run, { timeout: 2000 })
            : setTimeout(run, 0);

        document.addEventListener('DOMContentLoaded', init);
        document.addEventListener('astro:after-swap', run); // view-transition: run immediately, TTI already passed
    </script>
</Layout>
