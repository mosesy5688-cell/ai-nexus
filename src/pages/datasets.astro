---
/**
 * AI Datasets Catalog (V4.1)
 * Optimized SSR + UniversalCatalog Engine
 */
import Layout from '../layouts/Layout.astro';
import ListingControls from '../components/common/ListingControls.astro';
import { fetchCatalogData, truncateListingItem } from '../utils/catalog-fetcher.js';
import CatalogCard from '../components/common/CatalogCard.astro';

// SSR Data Fetching
const { items: allDatasets = [], totalPages, totalEntities, error } = await fetchCatalogData('dataset', Astro.locals.runtime?.env);
const datasets = allDatasets.slice(0, 24).map(truncateListingItem);

const pageTitle = "AI Datasets Catalog | Open Data Index";
const pageDescription = "Explore 50,000+ open-source AI datasets for training, evaluation, and fine-tuning.";

// V18.10.2: Explicit Edge Caching with Revalidation Guard
Astro.response.headers.set('Cache-Control', 'public, max-age=0, must-revalidate, s-maxage=60');
---

<Layout title={pageTitle} description={pageDescription}>
    <main class="min-h-screen py-4">
        <header class="mb-12">
            <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4 tracking-tight">
                AI Datasets <span class="text-sky-600">Archive</span>
            </h1>
            <p class="text-base text-gray-600 dark:text-zinc-400 max-w-2xl">
                The high-fidelity foundation for model intelligence. Diverse, massive, and sharded.
            </p>
        </header>

        <ListingControls type="dataset" searchId="datasets-search" />

        <div id="datasets-catalog-grid" class="flex flex-col gap-1">
            {datasets.map((dataset: any) => (
                <div class="animate-in fade-in slide-in-from-bottom-2 duration-300">
                    <CatalogCard item={dataset} type="dataset" />
                </div>
            ))}
        </div>

        <div id="pagination" class="mt-16 flex justify-center items-center gap-4"></div>
    </main>

    <script define:vars={{ initialData: datasets, totalPages, totalEntities }}>
        window.__CATALOG_DATA__ = {
            items: initialData,
            totalPages,
            totalEntities
        };
    </script>

    <script>
        import { UniversalCatalog } from '../scripts/lib/UniversalCatalog.js';
        
        const init = () => {
            new UniversalCatalog({
                initialData: window.__CATALOG_DATA__?.items || [],
                totalPages: window.__CATALOG_DATA__?.totalPages || 1,
                totalEntities: window.__CATALOG_DATA__?.totalEntities || 0,
                type: 'dataset',
                gridId: 'datasets-catalog-grid',
                searchId: 'datasets-search',
                dataUrl: 'https://cdn.free2aitools.com/cache/rankings/dataset/p1.json'
            });
        };

        document.addEventListener('astro:page-load', init);
    </script>
</Layout>
