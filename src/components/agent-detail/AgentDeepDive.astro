---
interface Props {
  agent: any;
}

const { agent } = Astro.props;
import FullReadmeSection from '../model-detail/FullReadmeSection.astro';
import MarkdownRenderer from '../model-detail/MarkdownRenderer.astro';

// V19: Removed dead mockConfig variable (fabricated YAML never rendered)
const agentName = agent?.name || agent?.canonical_name || 'unknown-agent';

// V19: Popularity metrics with defensive parsing
const downloads = agent?.downloads ? Number(agent.downloads) : null;
const likes = agent?.likes ? Number(agent.likes) : null;
---

   <div class="lg:col-span-3 space-y-8">
      {/* V19: Popularity Metrics (if available) */}
      {(downloads || likes) && (
        <section class="flex flex-wrap gap-4">
          {downloads && (
            <div class="flex items-center gap-2 px-4 py-2 bg-indigo-50 dark:bg-indigo-900/20 rounded-xl border border-indigo-100 dark:border-indigo-800/30">
              <span class="text-lg">⬇️</span>
              <div>
                <div class="text-[10px] font-bold uppercase tracking-widest text-gray-400">Downloads</div>
                <div class="text-sm font-black text-gray-900 dark:text-white">{downloads >= 1e6 ? `${(downloads/1e6).toFixed(1)}M` : downloads.toLocaleString()}</div>
              </div>
            </div>
          )}
          {likes && (
            <div class="flex items-center gap-2 px-4 py-2 bg-rose-50 dark:bg-rose-900/20 rounded-xl border border-rose-100 dark:border-rose-800/30">
              <span class="text-lg">❤️</span>
              <div>
                <div class="text-[10px] font-bold uppercase tracking-widest text-gray-400">Likes</div>
                <div class="text-sm font-black text-gray-900 dark:text-white">{likes.toLocaleString()}</div>
              </div>
            </div>
          )}
        </section>
      )}

      <!-- Full README / Agent Profile (V19: html_readme priority) -->
      <FullReadmeSection 
        bodyContent={agent.html_readme || agent.body_content || agent.description}
        type="agent"
        maxPreviewLength={5000}
      />



      {/* V16.2: Real Data Deep Dive */}
      {agent.installation && (
        <section class="bg-[var(--bg-surface)] rounded-sm p-6 border border-[var(--border-hairline)]">
          <h2 class="text-[10px] font-black text-zinc-500 uppercase tracking-widest mb-4 flex items-center gap-2">
            <span>💻</span> Installation
          </h2>
          <MarkdownRenderer content={agent.installation} />
        </section>
      )}

      {agent.configuration && (
        <section class="bg-[var(--bg-surface)] rounded-sm p-6 border border-[var(--border-hairline)]">
          <h2 class="text-[10px] font-black text-zinc-500 uppercase tracking-widest mb-4 flex items-center gap-2">
            <span>⚙️</span> Configuration
          </h2>
          <MarkdownRenderer content={agent.configuration} />
        </section>
      )}

      {agent.usage && (
        <section class="bg-[var(--bg-surface)] rounded-sm p-6 border border-[var(--border-hairline)]">
          <h2 class="text-[10px] font-black text-zinc-500 uppercase tracking-widest mb-4 flex items-center gap-2">
            <span>🚀</span> Usage Examples
          </h2>
          <MarkdownRenderer content={agent.usage} />
        </section>
      )}

      {agent.license_full && (
        <section class="bg-[var(--bg-surface)] rounded-sm p-6 border border-[var(--border-hairline)]">
          <h2 class="text-[10px] font-black text-zinc-500 uppercase tracking-widest mb-4 flex items-center gap-2">
            <span>📄</span> License Details
          </h2>
          <div class="bg-[var(--bg-canvas)] p-4 rounded-sm text-xs text-zinc-400 font-mono whitespace-pre-wrap border border-[var(--border-hairline)]">
            {agent.license_full}
          </div>
        </section>
      )}
   </div>
