---
interface Props {
  promptData: any;
}

const { promptData } = Astro.props;

const displayAuthor = promptData?.author || 'Community';
const likes = promptData?.likes || promptData?.stars ? Number(promptData?.likes || promptData?.stars) : null;

import FullReadmeSection from '../model-detail/FullReadmeSection.astro';
---

<div class="space-y-12">
  {likes && (
    <section class="flex flex-wrap gap-4">
      <div class="flex items-center gap-2 px-4 py-2 bg-[var(--bg-surface)] rounded-sm border border-[var(--border-hairline)]">
        <span class="text-lg">❤️</span>
        <div>
          <div class="text-[9px] font-black uppercase tracking-widest text-zinc-500">Likes</div>
          <div class="text-sm font-black text-white">{likes >= 1e6 ? `${(likes/1e6).toFixed(1)}M` : likes.toLocaleString()}</div>
        </div>
      </div>
    </section>
  )}

  <!-- Section: Prompt Spec Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
       <section class="bg-[var(--bg-surface)] rounded-sm p-8 border border-[var(--border-hairline)]">
         <h2 class="text-[10px] font-black mb-6 text-zinc-500 uppercase tracking-widest flex items-center gap-2">
            <span>📋</span> Specs
         </h2>
         <dl class="space-y-4 text-xs font-medium">
           <div class="flex justify-between items-center pb-4 border-b border-[var(--border-hairline)]">
             <dt class="text-zinc-500 uppercase tracking-widest text-[9px] font-black">Author</dt>
             <dd class="text-white font-bold">{displayAuthor}</dd>
           </div>
           {promptData.source_url && (
             <div class="mt-6">
               <a href={promptData.source_url} target="_blank" rel="noopener noreferrer"
                  class="flex items-center justify-center w-full px-4 py-2 bg-white text-black rounded-sm hover:bg-zinc-200 transition-colors font-bold text-xs uppercase tracking-tight">
                 Explore Source Node
               </a>
             </div>
           )}
         </dl>
       </section>
   </div>

  <!-- Section: Prompt Instruction / Markdown Priority -->
  <div class="relative">
     <div class="absolute -left-6 top-10 w-1 bg-indigo-500/20 h-24 rounded-full blur-sm"></div>
     <FullReadmeSection 
       bodyContent={promptData.html_readme || promptData.body_content || promptData.description || 'No prompt instructions available.'}
       type="prompt"
       initialCollapsed={false}
       maxPreviewLength={8000}
     />
  </div>
</div>
