---
/**
 * FNI Trust Panel Component
 * Constitution V3.3 Pillar VII: Fair Index Standard
 */

interface Props {
  fniScore: number;
  fniPercentile: number;
  fniP: number;
  fniV: number;
  fniC: number;
  fniU?: number;
  fniCommentary?: string;
  fniCalculatedAt?: string;
  modelName: string;
  modelId?: string;
}

const { 
  fniScore = 0, 
  fniPercentile = 0, 
  fniP = 0, 
  fniV = 0, 
  fniC = 0,
  fniU = 0,
  fniCommentary = '',
  fniCalculatedAt = '',
  modelName = '',
  modelId = ''
} = Astro.props;

// Calculate bar chart percentages
const maxScore = 100;
const pPercent = (fniP / maxScore) * 100;
const vPercent = (fniV / maxScore) * 100;
const cPercent = (fniC / maxScore) * 100;
const uPercent = (fniU / maxScore) * 100;

// Format date
const formattedDate = fniCalculatedAt 
  ? new Date(fniCalculatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : 'Not calculated';
---

<div class="fni-trust-panel bg-[var(--bg-surface)] rounded-sm p-6 border border-[var(--border-hairline)] relative overflow-hidden">
  <!-- Header -->
  <div class="flex items-center justify-between mb-6">
    <h3 class="text-sm font-black text-white flex items-center gap-2 uppercase tracking-tighter">
      <span class="opacity-60">⚖️</span>
      Nexus Index
    </h3>
    <div class="flex items-center gap-4">
      <a href="/methodology" class="text-[9px] font-black text-[#bdc3ff] hover:underline uppercase tracking-widest">
        Methodology
      </a>
      <a href="/knowledge#fni" class="text-[9px] font-black text-zinc-500 hover:underline uppercase tracking-widest">
        Index Protocol
      </a>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-8">
    <!-- Left: Score & Radar -->
    <div class="text-center md:text-left">
      <!-- Big Score -->
      <div class="flex flex-col mb-6">
        <div class="text-6xl font-black text-white tabular-nums tracking-tighter leading-none">
          {fniScore.toFixed(1)}
        </div>
        <div class="text-[10px] font-black text-zinc-500 uppercase tracking-[0.2em] mt-2">
          TOP {100 - fniPercentile}% SYSTEM IMPACT
        </div>
      </div>

      <!-- Simple Bar Chart -->
      <div class="space-y-4 text-left">
        <!-- Popularity -->
        <div>
          <div class="flex justify-between text-[9px] font-black uppercase tracking-widest mb-1.5">
            <span class="text-zinc-500">Popularity (P)</span>
            <span class="text-white tabular-nums">{fniP.toFixed(0)}</span>
          </div>
          <div class="h-1 bg-black/40 w-full rounded-full overflow-hidden">
            <div class="h-full bg-[#bdc3ff] transition-all duration-500" style={`width: ${pPercent}%`}></div>
          </div>
        </div>

        <!-- Velocity -->
        <div>
          <div class="flex justify-between text-[9px] font-black uppercase tracking-widest mb-1.5">
            <span class="text-zinc-500">Velocity (V)</span>
            <span class="text-white tabular-nums">{fniV.toFixed(0)}</span>
          </div>
          <div class="h-1 bg-black/40 w-full rounded-full overflow-hidden">
            <div class="h-full bg-[#bdc3ff] transition-all duration-500" style={`width: ${vPercent}%`}></div>
          </div>
        </div>

        <!-- Credibility -->
        <div>
          <div class="flex justify-between text-[9px] font-black uppercase tracking-widest mb-1.5">
            <span class="text-zinc-500">Credibility (C)</span>
            <span class="text-white tabular-nums">{fniC.toFixed(0)}</span>
          </div>
          <div class="h-1 bg-black/40 w-full rounded-full overflow-hidden">
            <div class="h-full bg-[#bdc3ff] transition-all duration-500" style={`width: ${cPercent}%`}></div>
          </div>
        </div>

        <!-- Utility -->
        <div>
          <div class="flex justify-between text-[9px] font-black uppercase tracking-widest mb-1.5">
            <span class="text-zinc-500">Utility (U)</span>
            <span class="text-white tabular-nums">{fniU.toFixed(0)}</span>
          </div>
          <div class="h-1 bg-black/40 w-full rounded-full overflow-hidden">
            <div class="h-full bg-[#bdc3ff] transition-all duration-500" style={`width: ${uPercent}%`}></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Commentary -->
    <div class="flex flex-col">
      <div class="bg-black/20 rounded-sm p-4 border border-white/5 flex-1 relative">
        <h4 class="text-[9px] font-black text-zinc-500 mb-3 flex items-center gap-2 uppercase tracking-widest">
          <span>💬</span> Why this score?
        </h4>
        <p class="text-[11px] text-zinc-400 leading-relaxed font-medium tracking-tight">
          {fniCommentary || `The Free2AITools Nexus Index for ${modelName} aggregates Popularity (P:${fniP.toFixed(0)}), Velocity (V:${fniV.toFixed(0)}), and Credibility (C:${fniC.toFixed(0)}). The Utility score (U:${fniU.toFixed(0)}) represents deployment readiness and structural reliability within the ecosystem.`}
        </p>
      </div>

      <div class="mt-4 bg-black/20 rounded-sm p-4 border border-white/5">
        <span class="text-xs font-black text-white/50 uppercase tracking-[0.2em] mb-1">Free2AITools</span>
        <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest mt-1">Nexus Index</span>
        <h4 class="text-[9px] font-black text-zinc-500 mb-2 uppercase tracking-widest">
          Verification Sources
        </h4>
        <div class="grid grid-cols-2 gap-x-4 gap-y-2 text-[10px] font-medium">
          <a href="https://huggingface.co/metrics" class="text-[#bdc3ff] hover:underline truncate">HuggingFace Stats</a>
          <a href="/methodology#velocity" class="text-[#bdc3ff] hover:underline truncate">7D Delta Tracker</a>
          <a href="https://paperswithcode.com" class="text-[#bdc3ff] hover:underline truncate">Arxiv Citations</a>
          <a href="/methodology#utility" class="text-[#bdc3ff] hover:underline truncate">Deploy Readiness</a>
        </div>
      </div>

      <div class="mt-6 pt-4 border-t border-white/5">
        <div class="flex items-center justify-between text-[9px] font-bold uppercase tracking-widest">
          <span class="flex items-center gap-1.5 text-[#bdc3ff]">
            <span class="w-1.5 h-1.5 rounded-full bg-[#bdc3ff] animate-pulse"></span>
            Data Verified
          </span>
          <span class="text-zinc-600">
            Updated: {fniCalculatedAt ? new Date(fniCalculatedAt).toISOString().split('T')[0] : 'Real-time'}
          </span>
        </div>
      </div>
    </div>
  </div>
</div>
