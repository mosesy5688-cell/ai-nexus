---
/**
 * FNIBadge.astro - Reusable FNI percentile badge component
 * Phase 9: Extracted for CES compliance (Art 5.1)
 */
interface Props {
  fniScore?: number;
  fniPercentile?: string;
  className?: string;
}

const { fniScore, fniPercentile, className = '' } = Astro.props;

// V25.1: Numeric Percentile Normalization (0-100 to Top X%)
let normalizedPercentile = fniPercentile;
if (typeof fniPercentile === 'number' || (typeof fniPercentile === 'string' && !isNaN(Number(fniPercentile)) && !fniPercentile.includes('%'))) {
    const p = Number(fniPercentile);
    if (p >= 99.9) normalizedPercentile = 'top_0.1%';
    else if (p >= 99) normalizedPercentile = 'top_1%';
    else if (p >= 95) normalizedPercentile = 'top_5%';
    else if (p >= 90) normalizedPercentile = 'top_10%';
    else if (p >= 75) normalizedPercentile = 'top_25%';
}

const badgeClass = 
  normalizedPercentile === 'top_0.1%' || normalizedPercentile === 'top_1%' 
    ? 'bg-gradient-to-r from-yellow-400 to-amber-500 text-white' 
  : normalizedPercentile === 'top_5%' || normalizedPercentile === 'top_10%'
    ? 'bg-gradient-to-r from-purple-500 to-indigo-600 text-white'
  : normalizedPercentile === 'top_25%'
    ? 'bg-gradient-to-r from-blue-500 to-cyan-500 text-white'
  : 'bg-indigo-600/90 text-white';

const displayText = normalizedPercentile?.startsWith?.('top_') 
  ? normalizedPercentile.replace('top_', 'Top ') 
  : `FNI ${Math.round(fniScore || 0)}`;
---

{(fniScore > 0 || fniPercentile) && (
  <div class={`text-xs px-2 py-1 rounded-full font-bold shadow-sm ${badgeClass} ${className}`}>
    ­¤øĪ’Ė?{displayText}
  </div>
)}
