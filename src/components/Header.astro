---
// V16.2: Updated Navigation - Focused on Core Features
// Removed: Compare (deprecated, not core feature)
const navLinks = [
  { href: "/", text: "Home" },
  { href: "/ranking", text: "Rankings" },
  { href: "/models", text: "Models" },
  { href: "/agents", text: "Agents" },
  { href: "/spaces", text: "Spaces" },
  { href: "/tools", text: "Tools" },
  { href: "/prompts", text: "Prompts" },
  { href: "/datasets", text: "Datasets" },
  { href: "/papers", text: "Papers" },
  { href: "/reports", text: "Reports" },
  { href: "/knowledge", text: "Knowledge" },
];

// External links
const externalLinks = [
  { href: "https://github.com/mosesy5688-cell/ai-nexus", text: "GitHub", icon: "github" },
];
---
<header class="sticky top-0 z-30 w-full backdrop-blur-md flex-none transition-all duration-500 lg:border-b border-gray-200 dark:border-gray-800 bg-white/70 dark:bg-gray-900/70 glass-effect" x-data="{ open: false }">
    <nav class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
            <!-- Site Logo (V16.5 Free2AI Branding) -->
            <a href="/" class="flex items-center gap-2 text-xl sm:text-2xl font-black text-gray-900 dark:text-white tracking-tighter group transition-all hover:scale-[1.02]">
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">Free2AITools</span>
            </a>
            
            <!-- Right-side items -->
            <div class="flex items-center gap-4">
                <!-- V22.9: Command Palette Trigger -->
                <button 
                  onclick="document.dispatchEvent(new KeyboardEvent('keydown', {ctrlKey: true, key: 'k'}))"
                  class="hidden md:flex items-center gap-2 px-3 py-1.5 rounded-md bg-white/5 border border-white/10 hover:border-white/20 transition-all text-xs text-white/40 group"
                >
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  </svg>
                  <span>Search...</span>
                  <kbd class="px-1 py-0.5 rounded bg-white/10 text-[10px] group-hover:text-white/60 transition-colors">Ctrl K</kbd>
                </button>

                <!-- Desktop Navigation (Consolidated) -->
                <div class="hidden lg:flex items-center gap-5">
                    {navLinks.slice(0, 6).map(link => (
                        <a href={link.href} class="text-sm font-medium text-gray-500 hover:text-white transition-colors">
                            {link.text}
                        </a>
                    ))}
                </div>

                <!-- Mobile Menu Toggle -->
                <button @click="open = !open" type="button" class="inline-flex items-center p-2 text-gray-400 rounded-lg md:hidden hover:bg-white/5">
                    <span class="sr-only">Open menu</span>
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path x-show="!open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        <path x-show="open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
        <!-- Mobile Collapsible Menu -->
        <div class="w-full md:hidden" id="navbar-default" x-show="open" x-transition>
            <ul class="font-medium flex flex-col p-4 md:p-0 mt-4 border border-gray-100 dark:border-gray-800 rounded-lg bg-gray-50 dark:bg-gray-800">
                {navLinks.map(link => (
                    <li>
                        <a href={link.href} class="block py-2 px-3 text-gray-900 dark:text-gray-100 rounded hover:bg-gray-100 dark:hover:bg-gray-700 md:hover:bg-transparent md:border-0 md:hover:text-blue-700 md:p-0 transition-colors">{link.text}</a>
                    </li>
                ))}
            </ul>
        </div>
    </nav>
</header>