---
// V16.2: Updated Navigation - Focused on Core Features
// Removed: Compare (deprecated, not core feature)
const navLinks = [
  { href: "/", text: "Home" },
  { href: "/ranking", text: "Rankings" },
  { href: "/models", text: "Models" },
  { href: "/agents", text: "Agents" },
  { href: "/spaces", text: "Spaces" },
  { href: "/tools", text: "Tools" },
  { href: "/prompts", text: "Prompts" },
  { href: "/datasets", text: "Datasets" },
  { href: "/papers", text: "Papers" },
  { href: "/reports", text: "Reports" },
  { href: "/knowledge", text: "Knowledge" },
];

// External links
const externalLinks = [
  { href: "https://github.com/mosesy5688-cell/ai-nexus/discussions", text: "GitHub", icon: "github" },
];
---
<header class="sticky top-0 z-[100] w-full bg-[#181818]/60 backdrop-blur-xl border-b border-[#272727] h-12 flex items-center" x-data="{ open: false }">
    <nav class="container mx-auto px-4 max-w-7xl">
        <div class="flex items-center justify-between">
            <!-- Site Logo (V22.11 Neutral Branding) -->
            <a href="/" class="flex items-center gap-2 text-lg font-black text-white tracking-widest uppercase transition-all hover:opacity-80">
                <span>free2aitools</span>
            </a>
            
            <!-- Right-side items -->
            <div class="flex items-center gap-6">
                <!-- Desktop Navigation (Consolidated and Muted) -->
                <div class="hidden lg:flex items-center gap-2 xl:gap-3">
                    {navLinks.map(link => (
                        <a href={link.href} class="text-[9px] font-black text-zinc-400 hover:text-white uppercase tracking-widest transition-colors whitespace-nowrap">
                            {link.text}
                        </a>
                    ))}
                    <div class="h-3 w-[1px] bg-[#272727] mx-1"></div>
                    <!-- Guide button — opens onboarding tour -->
                    <button type="button" onclick="window.openOnboardingTour?.()" class="text-[9px] font-black text-zinc-500 hover:text-white uppercase tracking-widest transition-colors whitespace-nowrap" title="New user guide">
                        Guide
                    </button>
                    <div class="h-3 w-[1px] bg-[#272727] mx-1"></div>
                    <!-- V22.10: Sticky Header Search Input -->
                    <form action="/search" method="get" data-astro-reload class="relative group ml-2 flex items-center">
                        <svg class="absolute left-2 w-3.5 h-3.5 text-zinc-400 group-focus-within:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                        <input 
                            type="search" 
                            name="q"
                            placeholder="Search..."
                            class="w-48 bg-white/5 border border-white/10 hover:border-white/20 focus:border-blue-500/50 focus:bg-[#181818] rounded-sm pl-8 pr-8 py-1.5 text-[11px] text-white placeholder-zinc-400 outline-none transition-all"
                            autocomplete="off"
                        />
                        <div class="absolute right-2 px-1 rounded bg-white/10 text-[8px] text-white/40 font-black cursor-pointer group-hover:bg-white/20 transition-colors pointer-events-none" title="Cmd+K to open Command Palette">
                            ⌘K
                        </div>
                    </form>
                </div>

                <!-- Mobile Search Icon (triggers Cmd+K palette) -->
                <button type="button" class="inline-flex items-center p-2 text-zinc-400 rounded-lg lg:hidden hover:bg-white/5" onclick="document.getElementById('search-modal')?.classList.remove('hidden');document.getElementById('palette-input')?.focus();" aria-label="Search">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </button>

                <!-- Mobile Menu Toggle -->
                <button @click="open = !open" type="button" class="inline-flex items-center p-2 text-zinc-400 rounded-lg lg:hidden hover:bg-white/5">
                    <span class="sr-only">Open menu</span>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path x-show="!open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                        <path x-show="open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
        <!-- Mobile Collapsible Menu (Industrial Dark) -->
        <div class="fixed inset-x-0 top-12 bg-[#181818] border-b border-[#272727] lg:hidden z-50" x-show="open" x-transition>
            <ul class="flex flex-col p-4 gap-2">
                {navLinks.map(link => (
                    <li>
                        <a href={link.href} class="block py-2 px-3 text-xs font-black text-zinc-400 hover:text-white uppercase tracking-widest transition-colors">{link.text}</a>
                    </li>
                ))}
                <li>
                    <button type="button" onclick="window.openOnboardingTour?.()" class="block w-full text-left py-2 px-3 text-xs font-black text-zinc-500 hover:text-white uppercase tracking-widest transition-colors">Guide</button>
                </li>
            </ul>
        </div>
    </nav>
</header>