---
/**
 * FNI Badge Component
 * 
 * Constitution V3.3 Pillar VII: Fair Index Standard
 * 
 * Displays the FNI percentile rank with tooltip showing raw score.
 * Strategy: Use percentile for badge, raw score in tooltip.
 */

interface Props {
  fniScore: number;
  fniPercentile: number;
  fniS?: number;
  fniA?: number;
  fniP?: number;
  fniR?: number;
  fniQ?: number;
  size?: 'sm' | 'md' | 'lg';
}

const {
  fniScore = 0,
  fniPercentile = 0,
  fniS = 50,
  fniA = 0,
  fniP = 0,
  fniR = 0,
  fniQ = 0,
  size = 'md'
} = Astro.props;

// Determine badge color based on percentile
// V4.8.2: Use score as fallback when percentile is 0 but score exists
function getBadgeColor(percentile: number, score: number): string {
  // If percentile not calculated but score exists, use score-based color
  if (percentile === 0 && score > 0) {
    if (score >= 80) return 'from-purple-500 to-indigo-600';
    if (score >= 60) return 'from-blue-500 to-cyan-500';
    if (score >= 40) return 'from-green-500 to-emerald-500';
    return 'from-gray-400 to-gray-500';
  }
  if (percentile >= 95) return 'from-yellow-400 to-amber-500'; // Elite
  if (percentile >= 90) return 'from-purple-500 to-indigo-600'; // Top 10%
  if (percentile >= 75) return 'from-blue-500 to-cyan-500'; // Top 25%
  if (percentile >= 50) return 'from-green-500 to-emerald-500'; // Top 50%
  return 'from-gray-400 to-gray-500'; // Lower 50%
}

function getBadgeLabel(percentile: number, score: number): string {
  // V4.8.2: Show score when percentile is not calculated
  if (percentile === 0 && score > 0) {
    return `📊 FNI ${score.toFixed(0)}`;
  }
  if (percentile >= 95) return '🏆 Elite';
  if (percentile >= 90) return '🥇 Top 10%';
  if (percentile >= 75) return '🥈 Top 25%';
  if (percentile >= 50) return '📊 Top 50%';
  return '📉 Emerging';
}

function getBadgeEmoji(percentile: number): string {
  if (percentile >= 95) return '🏆';
  if (percentile >= 90) return '🥇';
  if (percentile >= 75) return '🥈';
  if (percentile >= 50) return '🥉';
  return '📊';
}

const badgeColor = getBadgeColor(fniPercentile, fniScore);
const badgeLabel = getBadgeLabel(fniPercentile, fniScore);

const sizeClasses = {
  sm: 'px-2 py-1 text-xs',
  md: 'px-3 py-1.5 text-sm',
  lg: 'px-4 py-2 text-base'
};
---

<div class="fni-badge-container relative inline-block group">
  <!-- Main Badge -->
  <div class={`
    fni-badge inline-flex items-center gap-1.5 
    bg-gradient-to-r ${badgeColor} 
    text-white font-bold rounded-full shadow-lg
    ${sizeClasses[size]}
    cursor-help transition-all duration-300
    hover:scale-105 hover:shadow-xl
  `}>
    <span class="fni-label">{badgeLabel}</span>
  </div>

  <!-- Tooltip (shows on hover) -->
  <div class="fni-tooltip absolute bottom-full left-1/2 -translate-x-1/2 mb-2 
              opacity-0 group-hover:opacity-100 transition-opacity duration-200
              pointer-events-none z-50">
    <div class="bg-gray-900 text-white text-xs rounded-lg px-3 py-2 shadow-xl
                min-w-[180px]">
      <div class="font-bold text-center mb-2 border-b border-gray-700 pb-1">
        FNI Score: {fniScore.toFixed(1)}
      </div>
      <div class="grid grid-cols-5 gap-1.5 text-center">
        <div>
          <div class="text-cyan-400 font-semibold">{fniS.toFixed(0)}</div>
          <div class="text-gray-400 text-[10px]">Sem</div>
        </div>
        <div>
          <div class="text-green-400 font-semibold">{fniA.toFixed(0)}</div>
          <div class="text-gray-400 text-[10px]">Auth</div>
        </div>
        <div>
          <div class="text-blue-400 font-semibold">{fniP.toFixed(0)}</div>
          <div class="text-gray-400 text-[10px]">Pop</div>
        </div>
        <div>
          <div class="text-purple-400 font-semibold">{fniR.toFixed(0)}</div>
          <div class="text-gray-400 text-[10px]">Rec</div>
        </div>
        <div>
          <div class="text-orange-400 font-semibold">{fniQ.toFixed(0)}</div>
          <div class="text-gray-400 text-[10px]">Qual</div>
        </div>
      </div>
      <div class="text-center mt-2 text-[10px] text-gray-400">
        Free2AITools Nexus Index
      </div>
    </div>
    <!-- Tooltip Arrow -->
    <div class="absolute top-full left-1/2 -translate-x-1/2 
                border-4 border-transparent border-t-gray-900"></div>
  </div>
</div>

<style>
  .fni-badge-container:hover .fni-tooltip {
    opacity: 1;
  }
</style>
