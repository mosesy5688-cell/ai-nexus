---
/**
 * ListingControls Component - V16.9.23
 * Shared search, sort, and category filtering for all entity catalogs.
 * Standardized for 6 entity types (Models, Agents, Datasets, Papers, Spaces, Tools).
 */
import { CATEGORY_METADATA } from '../../utils/category-mapping.js';

interface Props {
  type: string;
  placeholder?: string;
  searchId?: string;
  sortId?: string;
  categoryFilterId?: string;
}

const { 
  type, 
  placeholder = `Search ${type}s...`, 
  searchId = `${type}s-search`,
  sortId = 'sort-by',
  categoryFilterId = 'category-filter'
} = Astro.props;

// Use standard V6 categories
const categories = Object.entries(CATEGORY_METADATA).map(([id, meta]) => ({
    id,
    label: meta.label,
    icon: meta.icon
}));
---

<div class="flex flex-wrap items-center gap-4 mb-6 px-3 py-3 bg-[#1e1e1e] border-b border-[#2a2a2a] z-10 relative">
  {/* Search Input */}
  <div class="flex-1 min-w-0 sm:min-w-[200px]">
    <div class="relative">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input
        type="text"
        id={searchId}
        placeholder={placeholder}
        class="w-full pl-9 pr-4 py-1.5 border border-[#2a2a2a] bg-[#181818] text-xs text-white placeholder-zinc-500 focus:border-zinc-600 outline-none transition-all rounded-sm"
      />
    </div>
  </div>

  <div class="flex flex-wrap items-center gap-4">
    {/* Category Filter */}
    <div class="flex items-center gap-2">
      <span class="text-[9px] font-black text-zinc-500 uppercase tracking-widest hidden sm:inline">Category:</span>
      <select id={categoryFilterId} class="pl-3 pr-8 py-1.5 border border-[#2a2a2a] bg-[#181818] text-[11px] font-bold text-zinc-300 focus:border-zinc-600 outline-none cursor-pointer appearance-none transition-colors rounded-sm">
        <option value="">All Categories</option>
        {categories.map(cat => (
            <option value={cat.id}>{cat.icon} {cat.label}</option>
        ))}
      </select>
    </div>

    {/* Result Count (Hydrated by JS) */}
    <span id="results-count" class="text-[9px] font-black text-zinc-500 uppercase tracking-widest hidden lg:inline px-2 py-1">
       Syncing...
    </span>

    {/* Sort Select */}
    <div class="flex items-center gap-2 border-l border-[#2a2a2a] pl-4">
      <span class="text-[9px] font-black text-zinc-500 uppercase tracking-widest hidden sm:inline">Sort:</span>
      <select id={sortId} class="pl-3 pr-8 py-1.5 border border-[#2a2a2a] bg-[#181818] text-[11px] font-bold text-zinc-300 focus:border-zinc-600 outline-none cursor-pointer appearance-none transition-colors rounded-sm">
        <option value="fni">FNI Score</option>
        {['model', 'agent', 'space'].includes(type) && <option value="downloads">Downloads</option>}
        {['model', 'agent', 'space'].includes(type) && <option value="likes">Likes</option>}
        <option value="recent">Updated</option>
        <option value="name">Name</option>
      </select>
    </div>
  </div>
</div>

<style>
  select {
    background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%23525252' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
    background-position: right 0.5rem center;
    background-repeat: no-repeat;
    background-size: 1.5em 1.5em;
  }
</style>
