---
/**
 * V22.10 SearchCommandPalette: Advanced Command Search Interface
 * Adheres to UI Iron Triangle: Minimalist, High-Density, Keyboard-First.
 * Supports: author: | task: | license: | params: | fni: | ctx:
 */
---

<div id="search-modal" class="fixed inset-0 z-[100] hidden bg-[#181818]/80 backdrop-blur-md flex items-start justify-center pt-[15vh] px-4" role="dialog" aria-modal="true" data-backdrop="true">
  <div class="w-full max-w-2xl bg-[#181818] border border-[#272727] rounded-sm overflow-hidden animate-in fade-in zoom-in duration-200" data-panel="true">
    <!-- Search Input -->
    <div class="relative border-b border-[#272727] p-4">
      <svg class="absolute left-7 top-1/2 -translate-y-1/2 w-5 h-5 text-zinc-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input 
        type="text" 
        id="palette-input"
        placeholder="Search models, tools, papers... or try author:meta params:>7b" 
        class="w-full bg-transparent pl-12 pr-4 py-2 text-xl text-white placeholder-zinc-500 outline-none font-medium"
        autocomplete="off"
        spellcheck="false"
      />
    </div>

    <!-- Results Area -->
    <div id="palette-results" class="max-h-[60vh] overflow-y-auto custom-scrollbar p-2 space-y-1 bg-black/20">
      <div id="palette-empty" class="py-12 text-center text-zinc-500">
        <p class="text-xs font-semibold">Start typing to search instantly</p>
        <p class="text-[10px] mt-4 text-zinc-500 font-medium leading-loose">
          💡 Try commands: <code class="px-1 bg-white/5 rounded border border-white/5">author:meta</code> <br/>
          <code class="px-1 bg-white/5 rounded border border-white/5">params:>7b</code> <code class="px-1 bg-white/5 rounded border border-white/5">fni:>50</code>
        </p>
        <p class="text-[8px] mt-6 font-black uppercase tracking-widest opacity-40">Press ESC to close</p>
      </div>
      <!-- Results injected here -->
    </div>

    <!-- Footer / Status -->
    <div class="border-t border-[#272727] p-3 flex items-center justify-between text-[10px] text-zinc-500 font-mono">
      <div id="engine-status" class="flex items-center gap-2">
         <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
         VFS Range Active (0ms)
      </div>
      <div class="flex items-center gap-4 text-xs font-sans">
        <span><b class="text-zinc-400">↑↓</b> Navigate</span>
        <span><b class="text-zinc-400">Enter</b> Open</span>
      </div>
    </div>
  </div>
</div>

<style>
  #palette-results::-webkit-scrollbar { width: 4px; }
  #palette-results::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.05); border-radius: 2px; }

  .result-item {
    @apply flex items-center gap-3 p-2 border border-transparent transition-all cursor-pointer;
  }
  .result-item.selected {
    @apply bg-[#313131] border-[#272727];
  }
</style>

<script>
  import { loadHotShard, searchShardPool } from '../../scripts/search-shard-engine.js';
  import { performSearch, initSearch } from '../../scripts/home-search.js';
  import { renderPaletteResults } from '../../scripts/lib/PaletteRenderer.js';

  const modal = document.getElementById('search-modal');
  const input = document.getElementById('palette-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('palette-results');
  const emptyState = document.getElementById('palette-empty');
  const engineStatus = document.getElementById('engine-status');
  let selectedIndex = -1;
  let currentAbort: AbortController | null = null;
  let dbFallbackTimer: ReturnType<typeof setTimeout> | null = null;
  let currentTier: 'shard' | 'db' | 'semantic' | 'loading' = 'shard';

  // 1. Initialize Hot Shard ASAP
  loadHotShard();

  // 2. Global Shortcuts
  window.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      toggleModal();
    }
    if (e.key === 'Escape' && !modal?.classList.contains('hidden')) {
      toggleModal(false);
    }
  });

  function toggleModal(show = true) {
    if (show) {
      modal?.classList.remove('hidden');
      input?.focus();
    } else {
      modal?.classList.add('hidden');
    }
  }

  function setEngineStatus(tier: 'shard' | 'db' | 'semantic' | 'loading') {
    if (!engineStatus) return;
    currentTier = tier;
    if (tier === 'shard') {
      engineStatus.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-blue-500 animate-pulse"></span> VFS Binary Active (0ms)`;
    } else if (tier === 'db') {
      engineStatus.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse"></span> meta.db Full Search`;
    } else if (tier === 'semantic') {
      engineStatus.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-rose-600 animate-pulse"></span> Tier 3 Semantic Engine`;
    } else {
      engineStatus.innerHTML = `<span class="w-1.5 h-1.5 rounded-full bg-yellow-400 animate-pulse"></span> Searching full database...`;
    }
  }

  // 3. Instant Search with AbortController race protection
  input?.addEventListener('input', () => {
    const query = input.value.trim();
    if (dbFallbackTimer) { clearTimeout(dbFallbackTimer); dbFallbackTimer = null; }
    if (currentAbort) { currentAbort.abort(); currentAbort = null; }

    if (!query) {
      if (resultsContainer) {
        resultsContainer.innerHTML = '';
        resultsContainer.appendChild(emptyState!);
      }
      setEngineStatus('shard');
      return;
    }

    // TIER 1: Instant Binary Shard Search (0ms)
    const shardResults = searchShardPool(query, 12, { sort: 'fni', entityType: 'all' });

    if (shardResults.length > 0) {
      setEngineStatus('shard');
      renderResults(shardResults);
    }

    // TIER 2: Always fire async upgrade (even if Tier 1 had results)
    // S0 edge cache makes this near-instant for repeated queries
    const abort = new AbortController();
    currentAbort = abort;

    dbFallbackTimer = setTimeout(async () => {
      if (abort.signal.aborted) return;

      // Only show loading spinner if Tier 1 had no results
      if (shardResults.length === 0) {
        setEngineStatus('loading');
        resultsContainer!.innerHTML = '<div class="py-8 text-center text-white/40 text-xs"><div class="inline-block w-4 h-4 border-2 border-white/20 border-t-white/60 rounded-full animate-spin mb-2"></div><p>Searching full database...</p></div>';
      }

      try {
        const dbResults = await performSearch(query, { sort: 'fni', entityType: 'all' }, 12, 0);
        if (abort.signal.aborted) return;

        if (dbResults && dbResults.length > 0) {
          if (currentTier !== 'semantic') setEngineStatus('db');
          renderResults(dbResults);
        } else if (shardResults.length === 0) {
          setEngineStatus('db');
          resultsContainer!.innerHTML = '<div class="py-12 text-center text-white/40 text-xs">No matches found. Try different keywords or use commands like <code class="px-1 bg-white/5 rounded">author:name</code></div>';
        }
      } catch (err) {
        if (abort.signal.aborted) return;
        console.warn('[Palette] Tier 2 failed:', err);
        if (shardResults.length === 0) {
          resultsContainer!.innerHTML = '<div class="py-12 text-center text-white/40 text-xs">Could not reach the full database.</div>';
        }
      }
    }, 150);
  });

  function renderResults(results: any[]) {
    renderPaletteResults(results, resultsContainer);
    selectedIndex = -1;
  }

  // 4. Keyboard Navigation (↑↓ + Enter)
  input?.addEventListener('keydown', (e) => {
    if (!resultsContainer) return;
    const items = resultsContainer.querySelectorAll('.result-item');
    if (items.length === 0) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
      updateSelection(items);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      selectedIndex = Math.max(selectedIndex - 1, 0);
      updateSelection(items);
    } else if (e.key === 'Enter' && selectedIndex >= 0 && selectedIndex < items.length) {
      e.preventDefault();
      (items[selectedIndex] as HTMLElement).click();
    }
  });

  function updateSelection(items: NodeListOf<Element>) {
    items.forEach((el, i) => {
      el.classList.toggle('selected', i === selectedIndex);
    });
    if (selectedIndex >= 0 && items[selectedIndex]) {
      items[selectedIndex].scrollIntoView({ block: 'nearest' });
    }
  }

  // 5. Backdrop Click to Close
  modal?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target === modal || (!target.closest('[data-panel]') && target.hasAttribute('data-backdrop'))) {
      toggleModal(false);
    }
  });

  // 6. Status Event Listener (V22.10 Tier signaling)
  window.addEventListener('search-status-change', (e: any) => {
    if (e.detail?.tier) setEngineStatus(e.detail.tier);
  });
</script>
