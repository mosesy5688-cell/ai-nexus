---
/**
 * MiniTrendChart Component
 * V14.5 Phase 5: Inline mini trend chart for FNI history
 * 
 * Usage: <MiniTrendChart entityId="model-id" />
 * 
 * Features:
 * - 7-day FNI trend sparkline (canvas)
 * - Change percentage badge (up/down/stable)
 * - Lazy loads trend data from CDN
 * - Zero dependencies (no Chart.js)
 */

interface Props {
    entityId: string;
    showBadge?: boolean;
    width?: number;
    height?: number;
    initialData?: number[];
}

const { 
    entityId, 
    showBadge = true,
    width = 80,
    height = 28,
    initialData
} = Astro.props;
---

<div 
    class="mini-trend-container" 
    data-entity-id={entityId}
    data-initial={initialData ? JSON.stringify(initialData) : undefined}
>
    <div class="mini-trend" data-w={width} data-h={height}>
        <canvas 
            class="mini-trend-canvas" 
            aria-label="7-day FNI trend"
        ></canvas>
        {showBadge && (
            <span class="mini-trend-badge" aria-live="polite">--</span>
        )}
    </div>
</div>

<style>
.mini-trend-container {
    width: 100%;
    overflow: hidden; /* V16.35: Prevent "out of box" overflow */
    display: flex;
    justify-content: center;
}

.mini-trend {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    max-width: 100%;
}

.mini-trend-canvas {
    opacity: 0.1;
    transition: opacity 0.5s ease;
    width: 100%; /* V16.35: Responsive width */
    height: auto;
}

.mini-trend-canvas.loaded {
    opacity: 1;
}

.mini-trend-badge {
    font-size: 11px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 6px;
    white-space: nowrap;
    background: var(--color-surface-2, #f3f4f6);
    color: var(--color-text-muted, #6b7280);
    border: 1px solid rgba(0,0,0,0.05);
}

.mini-trend-badge.up {
    background: #f0fdf4;
    color: #15803d;
}

.mini-trend-badge.down {
    background: #fef2f2;
    color: #b91c1c;
}

.mini-trend-badge.stable {
    background: #f9fafb;
    color: #4b5563;
}
.hidden { display: none !important; }
</style>

<script>
import { drawSparkline, updateBadge } from '../../utils/trend-helpers.js';

// V27.65 trend index swapped to /api/v1/trends/batch (data/* VFS via existing
// V27.27 trend-fetcher.js). Per-id lazy fetch with isolate-shared dedupe cache
// keyed by id; batched fan-out caps 16 ids per URL (CF edge 414 guard).
const MAX_BATCH_IDS = 16;
const _trendIndex: Record<string, any> = {};
const _inflight: Map<string, Promise<any>> = new Map();

async function fetchTrendBatch(ids: string[]): Promise<void> {
    const fresh = ids.filter(i => !(i in _trendIndex));
    if (fresh.length === 0) return;
    const safeIds = fresh.slice(0, MAX_BATCH_IDS).map(encodeURIComponent).join(',');
    if (!safeIds) return;
    try {
        const res = await fetch(`/api/v1/trends/batch?ids=${safeIds}`, { headers: { Accept: 'application/json' } });
        if (!res.ok) throw new Error(`HTTP_${res.status}`);
        const body = await res.json();
        const trends = body.trends || {};
        for (const k of Object.keys(trends)) _trendIndex[k] = trends[k];
        // Mark missing ids as null so subsequent calls don't re-fetch
        for (const id of fresh) if (!(id in _trendIndex)) _trendIndex[id] = null;
    } catch (e) {
        console.error('[MiniTrendChart:fetchTrendBatch]', (e as any)?.message);
        for (const id of fresh) _trendIndex[id] = null;
    }
}

async function getTrendFor(id: string): Promise<any> {
    if (id in _trendIndex) return _trendIndex[id];
    if (_inflight.has(id)) return _inflight.get(id);
    const p = fetchTrendBatch([id]).then(() => _trendIndex[id]);
    _inflight.set(id, p);
    try { return await p; } finally { _inflight.delete(id); }
}

async function initMiniTrends() {
    const containers = document.querySelectorAll('.mini-trend-container:not(.inited)');
    if (!containers.length) return;

    // V27.65: pre-fetch batch for containers without SSR data-initial (1 round-trip
    // covers up to MAX_BATCH_IDS=16; remainder fall back to per-id lazy on demand)
    const idsNeedingFetch = Array.from(containers)
        .filter(c => !(c as HTMLElement).dataset.initial)
        .map(c => (c as HTMLElement).dataset.entityId)
        .filter((v): v is string => !!v);
    if (idsNeedingFetch.length > 0) await fetchTrendBatch(idsNeedingFetch);

    containers.forEach(async (container) => {
        const el = container as HTMLElement;
        const id = el.dataset.entityId;
        if (!id) return;

        // V18.2.4: Priority 1 - Injected Initial Data (Instant)
        const initialStr = el.dataset.initial;
        let entityTrend = null;

        if (initialStr) {
            try {
                const scores = JSON.parse(initialStr);
                if (Array.isArray(scores) && scores.length > 0) {
                    const latest = scores[scores.length - 1];
                    const oldest = scores[0];
                    const change7d = oldest > 0 ? parseFloat(((latest - oldest) / oldest * 100).toFixed(1)) : 0;
                    let direction = 'stable';
                    if (change7d > 1) direction = 'up';
                    else if (change7d < -1) direction = 'down';

                    entityTrend = { scores, change7d, direction };
                }
            } catch (e) { console.error('Initial trend parse fail', e); }
        }

        // Priority 2 - API per-id (V27.65 lazy fetch via /api/v1/trends/batch)
        if (!entityTrend) entityTrend = await getTrendFor(id);

        const fallback = container.parentElement?.querySelector('#trend-fallback');

        if (!entityTrend || !Array.isArray(entityTrend.scores) || entityTrend.scores.length === 0) {
            if (fallback) {
                fallback.innerHTML = `<span class="opacity-60 italic api-fallback-err" data-component="mini-trend">Trend data unavailable</span>`;
                fallback.classList.remove('hidden');
            }
            return;
        }
        
        const d = entityTrend;
        const canvas = container.querySelector('canvas');
        const badge = container.querySelector('.mini-trend-badge') as HTMLElement;
        
        if (canvas) {
            const scores = d.scores || (d.latest ? [d.latest, d.latest] : []);
            if (scores.length >= 2) {
                drawSparkline(canvas as HTMLCanvasElement, scores, d.direction || 'stable');
                if (fallback) fallback.classList.add('hidden');
            }
        }
        if (badge) {
            updateBadge(badge, d.change7d || 0, d.direction || 'stable');
        }
        container.classList.add('inited');
    });
}

// Global Inits — defer to idle so chart setup doesn't block TTI
const deferMini = () => 'requestIdleCallback' in window
    ? requestIdleCallback(initMiniTrends, { timeout: 2000 })
    : setTimeout(initMiniTrends, 0);
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', deferMini);
} else {
    deferMini();
}
document.addEventListener('astro:page-load', initMiniTrends); // view-transition: run immediately
</script>
