---
/**
 * FullReadmeSection - V21.15.8 (Industrial Grade)
 * Enhanced for 100% data recovery and premium typography.
 * Implements "High-Fidelity First" recovery strategy.
 */
import MarkdownRenderer from './MarkdownRenderer.astro';
import { runNeuralMining } from '../../scripts/neural-miner.js';

interface Props { bodyContent: string; htmlReadme?: string; model?: any; type: string; title?: string; initialCollapsed?: boolean; maxPreviewLength?: number; }

const { 
  bodyContent, 
  htmlReadme,
  model, 
  type, 
  title = '', 
  initialCollapsed = true,
  maxPreviewLength = 8000
} = Astro.props;

// V25.1: Prefer pre-compiled html_readme from VFS Bundle — zero SSR marked.parse() overhead
const usePrecompiledHtml = !!(htmlReadme && htmlReadme.length > 10);
const rawContent = usePrecompiledHtml ? '' : (bodyContent || '').replace(/^[\s\n]*---\s*[\s\S]*?---\s*\n*/g, '');
function getTitle(type: string, manualTitle: string) {
  if (manualTitle) return manualTitle;
  switch (type) {
    case 'dataset': return 'Dataset Specification';
    case 'tool': return 'Technical Documentation';
    case 'agent': return 'Agent Architecture';
    case 'space': return 'Environment Profile';
    case 'paper': return 'Abstract & Analysis';
    default: return 'Technical Deep Dive';
  }
}

const displayTitle = getTitle(type, title);
const toggleLabel = type === 'dataset' ? 'Dataset Card' : (type === 'tool' ? 'Documentation' : 'README');

const content = usePrecompiledHtml ? htmlReadme! : rawContent;

const hasLongContent = content.length > maxPreviewLength;
---

{/* V22.8: Hybrid Hydration Gate. If content is missing at SSR, we render a VFS-Recovery skeleton. */}
<section class="readme-section relative group" id="technical-readme" 
         data-model-id={model?.id || ''} 
         data-model-type={type}
         data-has-initial={content ? 'true' : 'false'}>
  <div class="flex items-center justify-between mb-8">
    <div class="flex items-center gap-3">
       <div class="w-1.5 h-1.5 bg-indigo-500 rounded-full shadow-[0_0_8px_rgba(99,102,241,0.5)]"></div>
       <h2 class="text-[10px] font-black text-zinc-400 dark:text-zinc-500 uppercase tracking-[0.2em]">{displayTitle}</h2>
    </div>
    
    <div id="readme-status" class="hidden text-[8px] font-black text-indigo-400/50 uppercase tracking-widest animate-pulse">
       VFS Recovering Reference...
    </div>

    {hasLongContent && (
      <button id="readme-toggle-top" 
              class="text-[10px] font-black text-indigo-500 uppercase tracking-widest hover:text-indigo-400 transition-colors flex items-center gap-2 group/top">
         <span class="toggle-text">Full Specifications</span>
         <span class="icon transition-transform group-hover/top:translate-y-0.5">↓</span>
      </button>
    )}
  </div>

  <div class={`readme-container relative overflow-hidden transition-all duration-700 ease-in-out bg-[var(--bg-surface)] rounded-sm border border-[var(--border-hairline)]
                ${hasLongContent ? 'collapsed' : ''}`} 
       id="readme-container">
    
    <div class="p-6 sm:p-10" id="readme-content-target">
      {content ? (
        usePrecompiledHtml ? (
          <div class="markdown-content prose prose-sm md:prose-base dark:prose-invert max-w-none 
                      prose-headings:font-black prose-headings:tracking-tight prose-headings:text-zinc-900 dark:prose-headings:text-white
                      prose-a:text-[#bdc3ff] prose-a:font-bold prose-a:no-underline hover:prose-a:underline
                      prose-strong:text-zinc-900 dark:prose-strong:text-white
                      leading-relaxed tracking-tight" 
               set:html={content} />
        ) : (
          <MarkdownRenderer content={content} />
        )
      ) : (
        <div class="space-y-6 py-4">
          <div class="h-4 bg-gray-200 dark:bg-gray-800 rounded-full w-3/4 animate-shimmer"></div>
          <div class="h-4 bg-gray-200 dark:bg-gray-800 rounded-full w-full animate-shimmer" style="animation-delay: 0.2s"></div>
          <div class="h-4 bg-gray-200 dark:bg-gray-800 rounded-full w-5/6 animate-shimmer" style="animation-delay: 0.4s"></div>
          <div class="h-4 bg-gray-200 dark:bg-gray-800 rounded-full w-4/5 animate-shimmer" style="animation-delay: 0.6s"></div>
        </div>
      )}
    </div>

    {hasLongContent && (
      <div class="absolute bottom-0 left-0 right-0 h-64 bg-gradient-to-t from-white via-white/95 to-transparent dark:from-zinc-950 dark:via-zinc-950/95 pointer-events-none transition-opacity duration-500" id="readme-fade"></div>
    )}
  </div>

  <div id="readme-footer-container" class={hasLongContent ? '' : 'hidden'}>
    <div class="mt-8 flex justify-center">
      <button id="toggle-readme" 
              data-type-label={toggleLabel} 
              class="group flex flex-col items-center gap-3 py-4 px-12 rounded-sm hover:bg-[var(--bg-canvas)] transition-all border border-transparent hover:border-[var(--border-hairline)]">
        <span class="text-[10px] font-black text-indigo-500 uppercase tracking-[0.3em] group-hover:scale-110 transition-transform toggle-text">Expand full {toggleLabel}</span>
        <div class="flex flex-col items-center">
           <div class="w-px h-8 bg-gradient-to-b from-indigo-500 to-transparent toggle-line transition-all"></div>
           <span class="text-indigo-500 text-xs mt-1 animate-bounce toggle-icon">↓</span>
        </div>
      </button>
    </div>
  </div>
</section>

<script>
  import { runReadmeController } from '../../scripts/readme-controller.js';

  // Initial load
  runReadmeController();
  
  // View Transitions support
  document.addEventListener('astro:after-swap', runReadmeController);
</script>

<style>
  .readme-container.collapsed {
    max-height: 800px;
  }
  .rotate-180 {
    transform: rotate(180deg);
  }
  .opacity-0 {
    opacity: 0;
  }
  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  .animate-shimmer {
    background: linear-gradient(90deg, transparent 0%, rgba(128,128,128,0.05) 50%, transparent 100%);
    background-size: 200% 100%;
    animation: shimmer 2s infinite linear;
  }
</style>
