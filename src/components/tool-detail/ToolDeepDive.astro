---
interface Props {
  tool: any;
}

const { tool } = Astro.props;

const toolName = tool?.name || tool?.canonical_name || 'unknown-tool';

// V19: Use REAL usage data from fused entity, not fabricated code
const realUsage = tool?.usage || tool?.installation || null;

// V19: Popularity metrics with defensive parsing
const downloads = tool?.downloads ? Number(tool.downloads) : null;
const likes = tool?.likes ? Number(tool.likes) : null;

import FullReadmeSection from '../model-detail/FullReadmeSection.astro';
import MarkdownRenderer from '../model-detail/MarkdownRenderer.astro';
---

<div class="space-y-12">

  {/* V19: Popularity Metrics (if available) */}
  {(downloads || likes) && (
    <section class="flex flex-wrap gap-4">
      {downloads && (
        <div class="flex items-center gap-2 px-4 py-2 bg-indigo-50 dark:bg-indigo-900/20 rounded-xl border border-indigo-100 dark:border-indigo-800/30">
          <span class="text-lg">â¬‡ď¸Ź</span>
          <div>
            <div class="text-[10px] font-bold uppercase tracking-widest text-gray-400">Downloads</div>
            <div class="text-sm font-black text-gray-900 dark:text-white">{downloads >= 1e6 ? `${(downloads/1e6).toFixed(1)}M` : downloads.toLocaleString()}</div>
          </div>
        </div>
      )}
      {likes && (
        <div class="flex items-center gap-2 px-4 py-2 bg-rose-50 dark:bg-rose-900/20 rounded-xl border border-rose-100 dark:border-rose-800/30">
          <span class="text-lg">âť¤ď¸Ź</span>
          <div>
            <div class="text-[10px] font-bold uppercase tracking-widest text-gray-400">Likes</div>
            <div class="text-sm font-black text-gray-900 dark:text-white">{likes.toLocaleString()}</div>
          </div>
        </div>
      )}
    </section>
  )}

  <!-- Section: Tool Info & Classification (Grid) -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
       <section class="bg-[var(--bg-surface)] rounded-sm p-8 border border-[var(--border-hairline)]">
         <h2 class="text-[10px] font-black mb-6 text-zinc-500 uppercase tracking-widest flex items-center gap-2">
            <span>đź“‹</span> Specs
         </h2>
         <dl class="space-y-4 text-xs font-medium">
           <div class="flex justify-between items-center pb-4 border-b border-[var(--border-hairline)]">
             <dt class="text-zinc-500 uppercase tracking-widest text-[9px] font-black">Language</dt>
             <dd class="text-white font-bold">{tool.language || 'Python'}</dd>
           </div>
           <div class="flex justify-between items-center pb-4 border-b border-[var(--border-hairline)]">
             <dt class="text-zinc-500 uppercase tracking-widest text-[9px] font-black">License</dt>
             <dd class="text-white font-bold">{tool.license || 'Open Source'}</dd>
           </div>
           <div class="flex justify-between items-center">
             <dt class="text-zinc-500 uppercase tracking-widest text-[9px] font-black">Version</dt>
             <dd class="text-white font-bold">{tool.version || 'v1.0.0'}</dd>
           </div>
           {tool.source_url && (
             <div class="mt-6">
               <a href={tool.source_url} target="_blank" rel="noopener noreferrer"
                  class="flex items-center justify-center w-full px-4 py-2 bg-white text-black rounded-sm hover:bg-zinc-200 transition-colors font-bold text-xs uppercase tracking-tight">
                 Explore Source Node
               </a>
             </div>
           )}
         </dl>
       </section>

   </div>

  <!-- Section: Usage / API Integration (V19: Real data or Fallback) -->
  {realUsage ? (
    <section class="bg-[var(--bg-canvas)] rounded-sm p-8 border border-[var(--border-hairline)] relative overflow-hidden group">
       <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity">
          <span class="text-8xl text-indigo-500 select-none font-black">CODE</span>
       </div>
       <h2 class="text-[10px] font-black mb-6 text-zinc-500 uppercase tracking-widest flex items-center gap-2">
          <span>đź”Ś</span> Usage & Integration
       </h2>
       <MarkdownRenderer content={realUsage} />
    </section>
  ) : (
    <section class="bg-gray-50 dark:bg-gray-900/50 rounded-2xl p-8 border border-gray-200 dark:border-gray-800 text-center">
       <div class="text-4xl mb-4 opacity-40">đź“¦</div>
       <p class="text-sm text-gray-500 dark:text-gray-400 font-medium mb-4">
         Usage documentation not yet indexed for this tool.
       </p>
       {tool.source_url && (
         <a href={tool.source_url} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-bold text-xs uppercase tracking-tight shadow-lg hover:scale-105 transition-all">
           <span>đź”—</span> View Source Code â†?
         </a>
       )}
    </section>
  )}

  <!-- Section: README / Tool Card (V19: html_readme priority) -->
  <div class="relative">
     <div class="absolute -left-6 top-10 w-1 bg-indigo-500/20 h-24 rounded-full blur-sm"></div>
     <FullReadmeSection 
       bodyContent={tool.html_readme || tool.body_content || tool.description}
       type="tool"
       initialCollapsed={false}
       maxPreviewLength={5000}
     />
  </div>
</div>
