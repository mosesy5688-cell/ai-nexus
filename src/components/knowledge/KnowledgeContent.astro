import '../../styles/markdown-premium.css';
import { marked } from 'marked';

// Configure marked for information density styling
const htmlContent = marked.parse(content || '');
---

<article class="article-content markdown-content prose prose-sm md:prose-base dark:prose-invert max-w-none 
            prose-headings:font-black prose-headings:tracking-tight prose-headings:text-zinc-900 dark:prose-headings:text-white
            prose-a:text-[#bdc3ff] prose-a:font-bold prose-a:no-underline hover:prose-a:underline
            prose-img:rounded-sm prose-img:border prose-img:border-[var(--border-hairline)]
            prose-strong:text-zinc-900 dark:prose-strong:text-white
            leading-relaxed tracking-tight" 
         set:html={htmlContent} />

<script>
  import { initMarkdownCopy, initSmartTooltips } from '../../scripts/markdown-controller.js';

  function run() {
    initMarkdownCopy();
    initSmartTooltips();
  }

  // Initial load
  run();
  
  // View Transitions support
  document.addEventListener('astro:after-swap', run);
</script>
