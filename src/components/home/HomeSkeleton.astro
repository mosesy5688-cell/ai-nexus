---
// src/components/home/HomeSkeleton.astro
interface Props {
  count?: number;
}

const { count = 12 } = Astro.props;
---
<div id="hot-models-loading" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
    {Array.from({length: count}).map(() => (
        <div class="skeleton-card overflow-hidden bg-white dark:bg-zinc-900 rounded-md transition-all border border-zinc-100 dark:border-zinc-800 relative h-full flex flex-col">
            <div class="shimmer-wrapper absolute inset-0 -translate-x-full animate-shimmer z-10 pointer-events-none">
                <div class="h-full w-1/2 bg-gradient-to-r from-transparent via-white/20 to-transparent skew-x-[-20deg]"></div>
            </div>
            
            <div class="p-3 space-y-3 flex-grow">
                <!-- Type Badge & FNI Slot -->
                <div class="flex items-center justify-between mb-2">
                    <div class="h-4 w-16 bg-gray-100 dark:bg-zinc-800 rounded"></div>
                    <div class="h-4 w-12 bg-gray-100 dark:bg-zinc-800 rounded"></div>
                </div>

                <!-- Title -->
                <div class="h-4 bg-gray-200 dark:bg-gray-700 rounded w-3/4 mb-1.5"></div>
                <!-- Author -->
                <div class="h-3 bg-gray-100 dark:bg-zinc-800 rounded w-1/2 mb-2"></div>
                <!-- Description lines -->
                <div class="space-y-2 mb-3">
                    <div class="h-3 bg-gray-100 dark:bg-zinc-800 rounded w-full"></div>
                    <div class="h-3 bg-gray-100 dark:bg-zinc-800 rounded w-5/6"></div>
                </div>
                
                <!-- Metrics row (Footer) -->
                <div class="flex items-center gap-3 pt-2 border-t border-zinc-50 dark:border-zinc-800 mt-auto">
                    <div class="h-3 w-12 bg-gray-100 dark:bg-zinc-800 rounded"></div>
                    <div class="h-3 w-12 bg-gray-100 dark:bg-zinc-800 rounded"></div>
                </div>
            </div>
        </div>
    ))}
</div>

<style>
    @keyframes shimmer {
        100% {
            transform: translateX(100%);
        }
    }
    .animate-shimmer {
        animation: shimmer 1.5s infinite linear;
    }
</style>
