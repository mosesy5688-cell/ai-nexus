---
// src/components/home/HomeCategoryGrid.astro
---
<section id="category-section" class="mb-16 mt-8 hide-on-search">
    <div class="flex items-center gap-4 mb-8">
        <h2 class="text-xl md:text-2xl font-black text-zinc-900 dark:text-white uppercase tracking-tighter">
            Intelligence Segments
        </h2>
        <div class="h-px flex-grow bg-zinc-100 dark:bg-zinc-800"></div>
    </div>
    
    <div class="flex md:grid md:grid-cols-2 lg:grid-cols-3 gap-3 overflow-x-auto md:overflow-visible pb-4 md:pb-0 snap-x snap-mandatory scroll-smooth -mx-4 px-4 md:mx-0 md:px-0">
        <!-- Text Generation -->
        <a href="/text-generation" class="group relative bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3.5 transition-all hover:border-indigo-500/50 hover:shadow-sm snap-start flex-shrink-0 min-w-[240px] md:min-w-0" data-category="text-generation">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 flex items-center justify-center bg-zinc-50 dark:bg-zinc-800 rounded-lg border border-zinc-100 dark:border-zinc-700 text-lg group-hover:scale-105 transition-transform">💬</div>
                <h3 class="text-sm font-black text-zinc-900 dark:text-white tracking-tight group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors uppercase">Text Generation</h3>
            </div>
            <p class="text-[11px] text-zinc-500 dark:text-zinc-400 font-medium leading-tight mb-2 pl-11">Core LLMs, code assistants, and reasoning engines.</p>
            <div class="pl-11 font-black text-[9px] text-indigo-500 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">Explore segment →</div>
        </a>
        
        <!-- Knowledge Retrieval -->
        <a href="/knowledge-retrieval" class="group relative bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3.5 transition-all hover:border-emerald-500/50 hover:shadow-sm snap-start flex-shrink-0 min-w-[240px] md:min-w-0" data-category="knowledge-retrieval">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 flex items-center justify-center bg-zinc-50 dark:bg-zinc-800 rounded-lg border border-zinc-100 dark:border-zinc-700 text-lg group-hover:scale-105 transition-transform">🔍</div>
                <h3 class="text-sm font-black text-zinc-900 dark:text-white tracking-tight group-hover:text-emerald-600 transition-colors uppercase">Knowledge Retrieval</h3>
            </div>
            <p class="text-[11px] text-zinc-500 dark:text-zinc-400 font-medium leading-tight mb-2 pl-11">Embeddings, RAG components, and semantic search.</p>
            <div class="pl-11 font-black text-[9px] text-emerald-500 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">Explore segment →</div>
        </a>
        
        <!-- Vision & Multimedia -->
        <a href="/vision-multimedia" class="group relative bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3.5 transition-all hover:border-amber-500/50 hover:shadow-sm snap-start flex-shrink-0 min-w-[240px] md:min-w-0" data-category="vision-multimedia">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 flex items-center justify-center bg-zinc-50 dark:bg-zinc-800 rounded-lg border border-zinc-100 dark:border-zinc-700 text-lg group-hover:scale-105 transition-transform">🎨</div>
                <h3 class="text-sm font-black text-zinc-900 dark:text-white tracking-tight group-hover:text-amber-500 transition-colors uppercase">Vision & Multimedia</h3>
            </div>
            <p class="text-[11px] text-zinc-500 dark:text-zinc-400 font-medium leading-tight mb-2 pl-11">Diffusion, video processing, and audio synthesis.</p>
            <div class="pl-11 font-black text-[9px] text-amber-600 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">Explore segment →</div>
        </a>
        
        <!-- Automation -->
        <a href="/automation-workflow" class="group relative bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3.5 transition-all hover:border-violet-500/50 hover:shadow-sm snap-start flex-shrink-0 min-w-[240px] md:min-w-0" data-category="automation-workflow">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 flex items-center justify-center bg-zinc-50 dark:bg-zinc-800 rounded-lg border border-zinc-100 dark:border-zinc-700 text-lg group-hover:scale-105 transition-transform">⚡</div>
                <h3 class="text-sm font-black text-zinc-900 dark:text-white tracking-tight group-hover:text-violet-500 transition-colors uppercase">Automation</h3>
            </div>
            <p class="text-[11px] text-zinc-500 dark:text-zinc-400 font-medium leading-tight mb-2 pl-11">Agents, task-specific pipelines, and orchestration.</p>
            <div class="pl-11 font-black text-[9px] text-violet-500 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">Explore segment →</div>
        </a>
        
        <!-- Infrastructure -->
        <a href="/infrastructure-ops" class="group relative bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-xl p-3.5 transition-all hover:border-zinc-500/50 hover:shadow-sm snap-start flex-shrink-0 min-w-[240px] md:min-w-0" data-category="infrastructure-ops">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 flex items-center justify-center bg-zinc-50 dark:bg-zinc-800 rounded-lg border border-zinc-100 dark:border-zinc-700 text-lg group-hover:scale-105 transition-transform">🔧</div>
                <h3 class="text-sm font-black text-zinc-900 dark:text-white tracking-tight group-hover:text-zinc-600 transition-colors uppercase">Infrastructure</h3>
            </div>
            <p class="text-[11px] text-zinc-500 dark:text-zinc-400 font-medium leading-tight mb-2 pl-11">Quantization, serving stacks, and optimization.</p>
            <div class="pl-11 font-black text-[9px] text-zinc-500 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">Explore segment →</div>
        </a>
    </div>
</section>
