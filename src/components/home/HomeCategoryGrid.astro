---
// src/components/home/HomeCategoryGrid.astro
---
<section id="category-section" class="mb-16 mt-8 hide-on-search">
    <div class="flex items-center gap-4 mb-8">
        <h2 class="text-xl md:text-2xl font-black text-zinc-900 dark:text-white uppercase tracking-tighter">
            Intelligence Segments
        </h2>
        <div class="h-px flex-grow bg-zinc-100 dark:bg-zinc-800"></div>
    </div>
    
    <div class="flex md:grid md:grid-cols-2 lg:grid-cols-3 gap-3 overflow-x-auto md:overflow-visible pb-4 md:pb-0 snap-x snap-mandatory scroll-smooth -mx-4 px-4 md:mx-0 md:px-0">
        <!-- Text Generation -->
        <a href="/text-generation" class="group relative bg-[var(--bg-surface)] border border-[var(--border-hairline)] rounded-sm p-4 transition-all hover:border-zinc-600 flex-shrink-0 min-w-[240px] md:min-w-0" data-category="text-generation">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 flex items-center justify-center bg-black/20 rounded-md border border-white/5 text-lg group-hover:scale-105 transition-transform opacity-60">💬</div>
                <h3 class="text-sm font-black text-white tracking-widest group-hover:text-[#bdc3ff] transition-colors uppercase">Text Generation</h3>
            </div>
            <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-tight leading-tight mb-2 pl-11">Core LLMs, code assistants, and reasoning engines.</p>
            <div class="pl-11 font-black text-[9px] text-zinc-400 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">Access Segment →</div>
        </a>
        
        <!-- Knowledge Retrieval -->
        <a href="/knowledge-retrieval" class="group relative bg-[var(--bg-surface)] border border-[var(--border-hairline)] rounded-sm p-4 transition-all hover:border-zinc-600 flex-shrink-0 min-w-[240px] md:min-w-0" data-category="knowledge-retrieval">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 flex items-center justify-center bg-black/20 rounded-md border border-white/5 text-lg group-hover:scale-105 transition-transform opacity-60">🔍</div>
                <h3 class="text-sm font-black text-white tracking-widest group-hover:text-[#bdc3ff] transition-colors uppercase">Knowledge Retrieval</h3>
            </div>
            <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-tight leading-tight mb-2 pl-11">Embeddings, RAG components, and semantic search.</p>
            <div class="pl-11 font-black text-[9px] text-zinc-400 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">Access Segment →</div>
        </a>
        
        <!-- Vision & Multimedia -->
        <a href="/vision-multimedia" class="group relative bg-[var(--bg-surface)] border border-[var(--border-hairline)] rounded-sm p-4 transition-all hover:border-zinc-600 flex-shrink-0 min-w-[240px] md:min-w-0" data-category="vision-multimedia">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 flex items-center justify-center bg-black/20 rounded-md border border-white/5 text-lg group-hover:scale-105 transition-transform opacity-60">🎨</div>
                <h3 class="text-sm font-black text-white tracking-widest group-hover:text-[#bdc3ff] transition-colors uppercase">Vision Hub</h3>
            </div>
            <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-tight leading-tight mb-2 pl-11">Diffusion, video processing, and audio synthesis.</p>
            <div class="pl-11 font-black text-[9px] text-zinc-400 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">Access Segment →</div>
        </a>
        
        <!-- Automation -->
        <a href="/automation-workflow" class="group relative bg-[var(--bg-surface)] border border-[var(--border-hairline)] rounded-sm p-4 transition-all hover:border-zinc-600 flex-shrink-0 min-w-[240px] md:min-w-0" data-category="automation-workflow">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 flex items-center justify-center bg-black/20 rounded-md border border-white/5 text-lg group-hover:scale-105 transition-transform opacity-60">⚡</div>
                <h3 class="text-sm font-black text-white tracking-widest group-hover:text-[#bdc3ff] transition-colors uppercase">Automation</h3>
            </div>
            <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-tight leading-tight mb-2 pl-11">Agents, task-specific pipelines, and orchestration.</p>
            <div class="pl-11 font-black text-[9px] text-zinc-400 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">Access Segment →</div>
        </a>
        
        <!-- Infrastructure -->
        <a href="/infrastructure-ops" class="group relative bg-[var(--bg-surface)] border border-[var(--border-hairline)] rounded-sm p-4 transition-all hover:border-zinc-600 flex-shrink-0 min-w-[240px] md:min-w-0" data-category="infrastructure-ops">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-8 h-8 flex items-center justify-center bg-black/20 rounded-md border border-white/5 text-lg group-hover:scale-105 transition-transform opacity-60">🔧</div>
                <h3 class="text-sm font-black text-white tracking-widest group-hover:text-[#bdc3ff] transition-colors uppercase">Infrastructure</h3>
            </div>
            <p class="text-[10px] text-zinc-400 font-bold uppercase tracking-tight leading-tight mb-2 pl-11">Quantization, serving stacks, and optimization.</p>
            <div class="pl-11 font-black text-[9px] text-zinc-400 uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-opacity">Access Segment →</div>
        </a>
    </div>
</section>
