---
// src/components/home/HomeTechnicalHeader.astro
// V21.16: Premium Technical Header (Copy of Knowledge page architecture)
import MeshVisualizer from '../mesh/MeshVisualizer.astro';
import { loadSiteMetadata } from '../../utils/vfs-site-metadata.js';

interface Props {
  initialQuery?: string;
  totalEntities?: number;
}

const { initialQuery = '', totalEntities = 460000 } = Astro.props;

let totalNodes = totalEntities;
try {
  const data = await loadSiteMetadata('mesh_stats');
  if (data && data.nodes) totalNodes = data.nodes;
} catch (e) {}

---

<div class="technical-header-container mb-12 border-b border-[var(--border-hairline)] pb-12">
    <!-- Hero Section: V25.1 Industrial Mirror -->
    <header class="text-left mb-10 pt-6">
      <div class="flex items-center gap-2 mb-4">
          <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-[0.2em] font-mono">Updated Daily</span>
          <span class="w-1 h-1 bg-indigo-500/50 rounded-full"></span>
          <span class="text-[10px] font-bold text-indigo-500/70 uppercase tracking-widest">FNI Ranked</span>
      </div>

      <h1 class="text-3xl md:text-5xl font-bold text-[var(--text-strong)] mb-4 tracking-tight leading-tight uppercase">
        The Open-Source <span class="text-zinc-500">AI Registry</span>
      </h1>

      <div class="max-w-xl">
        <p class="text-sm text-zinc-500 leading-relaxed tracking-tight mb-4">
          Discover and rank {totalNodes.toLocaleString()}+ models, datasets, papers, and tools. Scored by the Federated Neural Index (FNI).
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/developers" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-indigo-400 border border-indigo-500/30 rounded hover:bg-indigo-500/10 transition-colors">
            REST API
          </a>
          <a href="/developers#mcp" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-indigo-400 border border-indigo-500/30 rounded hover:bg-indigo-500/10 transition-colors">
            MCP Server
          </a>
          <a href="/developers#badge" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-zinc-500 border border-zinc-700 rounded hover:bg-zinc-800 transition-colors">
            FNI Badge
          </a>
        </div>
      </div>
    </header>

    <!-- V25.1.1: Functional Search Input -->
    <div class="max-w-3xl mr-auto mb-10 group mt-8">
      <form action="/search" method="get" data-astro-reload
        class="relative border border-[#272727] bg-[#313131]/10 rounded p-0.5 transition-all flex items-center gap-0 focus-within:border-zinc-700"
      >
        <div class="pl-4 pr-3 py-4 border-r border-[#272727] flex items-center justify-center bg-black/10">
            <svg class="w-5 h-5 text-zinc-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
        </div>
        <input
          type="search"
          name="q"
          id="home-direct-input"
          placeholder="DISCOVER, FILTER, INTEGRATE..."
          class="block w-full px-6 py-4 bg-transparent text-lg md:text-xl font-bold text-[var(--text-strong)] placeholder-zinc-600 outline-none uppercase tracking-tight"
          autocomplete="off"
          spellcheck="false"
        />
        <div class="absolute inset-y-0 right-0 pr-8 flex items-center gap-3 pointer-events-none">
           <div class="px-2 py-1 rounded bg-white/5 border border-white/10 font-mono text-[9px] font-bold text-zinc-600 uppercase tracking-widest">
              Enter
           </div>
        </div>
      </form>

      <!-- Search Hints — navigate to /search?q=... -->
      <div class="mt-4 flex flex-wrap gap-6 text-[9px] text-zinc-700 font-bold uppercase tracking-widest">
          <span class="text-zinc-500">Quick Search:</span>
          {['Llama-3.1', 'Flux', 'Agentic-Workflows', 'FTS5-Search'].map(q => (
              <a
                href={`/search?q=${encodeURIComponent(q)}`}
                class="hover:text-white transition-colors border-b border-zinc-800 pb-0.5"
              >
                {q}
              </a>
          ))}
      </div>
    </div>

    <!-- Knowledge Mesh Integration (Upper Area) -->
    <section class="mb-10 opacity-60 hover:opacity-100 transition-opacity">
      <MeshVisualizer />
    </section>
</div>


<style>
  .technical-header-container {
    animation: fade-in-up 0.6s ease-out;
  }
  
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
