---
// src/components/home/HomeTechnicalHeader.astro
// V21.16: Premium Technical Header (Copy of Knowledge page architecture)
import MeshVisualizer from '../mesh/MeshVisualizer.astro';
import { loadCachedJSON } from '../../utils/loadCachedJSON.js';

interface Props {
  initialQuery?: string;
  totalEntities?: number;
}

const { initialQuery = '', totalEntities = 125312 } = Astro.props;

let totalNodes = totalEntities;
try {
  const { data } = await loadCachedJSON('cache/mesh/stats.json', { locals: Astro.locals });
  if (data && data.nodes) totalNodes = data.nodes;
} catch (e) {}

---

<div class="technical-header-container mb-12 border-b border-[var(--border-hairline)] pb-12">
    <!-- Hero Section: V25.1 Industrial Mirror -->
    <header class="text-left mb-10 pt-6">
      <div class="flex items-center gap-2 mb-4">
          <span class="text-[10px] font-black text-zinc-500 uppercase tracking-[0.3em] font-mono">Global Mesh Node</span>
          <span class="w-1 h-1 bg-indigo-500 rounded-full"></span>
          <span class="text-[10px] font-black text-indigo-500 uppercase tracking-widest">Active Runtime</span>
      </div>

      <h1 class="text-4xl md:text-7xl font-black text-white mb-6 tracking-tighter leading-none uppercase">
        Explore the <span class="text-zinc-500">AI Ecosystem</span>
      </h1>
      
      <div class="max-w-2xl">
        <p class="text-sm md:text-base text-zinc-400 font-medium leading-relaxed tracking-tight">
          The definitive open-source intelligence index. Discover, bench, and integrate 120K+ models, agents, and research nodes via UMID-verified pipelines.
        </p>
      </div>
    </header>

    <!-- V24.10d: Search Input — navigates to /search page (same as header) -->
    <div class="max-w-4xl mr-auto mb-10 group mt-12">
      <form action="/search" method="get" data-astro-reload
        class="relative border border-[#272727] bg-[#313131]/20 backdrop-blur-md rounded-lg p-1 transition-all flex items-center gap-0 group-hover:border-zinc-700/50"
      >
        <div class="pl-6 pr-4 py-6 border-r border-[#272727] flex items-center justify-center bg-black/20 rounded-l">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
        </div>
        <input
          type="search"
          name="q"
          id="home-direct-input"
          placeholder="DISCOVER, FILTER, INTEGRATE..."
          class="block w-full px-8 py-6 bg-transparent text-2xl md:text-3xl font-black text-white placeholder-zinc-500 outline-none uppercase tracking-tighter"
          autocomplete="off"
          spellcheck="false"
        />
        <div class="absolute inset-y-0 right-0 pr-8 flex items-center gap-3 pointer-events-none">
           <div class="px-2 py-1 rounded bg-white/5 border border-white/10 font-mono text-[9px] font-black text-zinc-600 uppercase tracking-widest">
              Enter
           </div>
        </div>
      </form>

      <!-- Search Hints — navigate to /search?q=... -->
      <div class="mt-4 flex flex-wrap gap-6 text-[9px] text-zinc-700 font-black uppercase tracking-widest">
          <span class="text-zinc-400">Quick Search:</span>
          {['Llama-3.1', 'Flux', 'Agentic-Workflows', 'FTS5-Search'].map(q => (
              <a
                href={`/search?q=${encodeURIComponent(q)}`}
                class="hover:text-white transition-colors border-b border-zinc-800 pb-0.5"
              >
                {q}
              </a>
          ))}
      </div>
    </div>

    <!-- Knowledge Mesh Integration (Upper Area) -->
    <section class="mb-10 opacity-60 hover:opacity-100 transition-opacity">
      <MeshVisualizer />
    </section>
</div>


<style>
  .technical-header-container {
    animation: fade-in-up 0.6s ease-out;
  }
  
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
