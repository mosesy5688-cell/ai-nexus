---
// src/components/home/HomeTechnicalHeader.astro
// V21.16: Premium Technical Header (Copy of Knowledge page architecture)
import MeshVisualizer from '../mesh/MeshVisualizer.astro';

interface Props {
  initialQuery?: string;
  totalEntities?: number;
}

const { initialQuery = '', totalEntities = 125312 } = Astro.props;
---

<div class="technical-header-container mb-12">
    <!-- Hero Section: Mirrored from /knowledge -->
    <header class="text-center mb-10 py-10 bg-gradient-to-br from-indigo-600/20 via-purple-600/10 to-pink-500/10 rounded-2xl border border-indigo-500/20">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-2xl mb-4 shadow-lg shadow-indigo-500/25">
        <span class="text-3xl">🕸️</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-extrabold text-gray-900 dark:text-white mb-4 tracking-tight">
        The Definitive Open-Source AI Index
      </h1>
      <p class="text-base md:text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto mb-6 px-4">
        High-trust technical rankings, structural lineage, and precision performance metrics for the entire AI ecosystem.
      </p>
      
      <div class="flex items-center justify-center gap-4 text-xs font-bold uppercase tracking-widest">
        <div class="flex items-center gap-2 px-3 py-1.5 bg-indigo-100 dark:bg-indigo-900/40 rounded-full text-indigo-700 dark:text-indigo-300 border border-indigo-500/10">
          <span>ACTIVE</span>
          <span class="w-1 h-1 rounded-full bg-emerald-500"></span>
        </div>
      </div>
    </header>

    <!-- V22.9: Industrial Search Input (Syncs with Command Palette) -->
    <div class="max-w-3xl mx-auto mb-10 group">
      <div 
        class="relative border border-white/10 hover:border-white/20 bg-white/5 backdrop-blur-md rounded-2xl p-2 transition-all flex items-center gap-4 group-hover:bg-white/10 shadow-2xl shadow-indigo-500/5"
      >
        <svg class="w-6 h-6 text-indigo-500/40 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input 
          type="text"
          id="home-direct-input"
          placeholder="Search entities instantly..." 
          class="flex-1 bg-transparent border-none text-xl text-white outline-none placeholder-white/30 font-light tracking-tight py-2"
          autocomplete="off"
        />
        <div class="flex items-center gap-2 px-3 py-1.5 mr-1 rounded-lg bg-black/40 border border-white/10 text-xs text-white/40 font-mono tracking-tighter cursor-pointer hover:bg-white/10" onclick="document.dispatchEvent(new KeyboardEvent('keydown', {ctrlKey: true, key: 'k'}))">
          <span class="opacity-50 hidden sm:inline">PRESS</span>
          <kbd class="text-white/60 font-bold">CTRL K</kbd>
        </div>
      </div>
      
      <!-- Search Hints (Concise) -->
      <div class="mt-5 flex flex-wrap justify-center gap-4 text-[10px] text-gray-500 dark:text-white/20 font-bold uppercase tracking-[0.2em]">
          <span class="opacity-40">Quick Access:</span>
          {['Llama 3.1', 'Flux.1', 'Qwen 2.5', 'SDXL'].map(q => (
              <button 
                onclick={`document.dispatchEvent(new KeyboardEvent('keydown', {ctrlKey: true, key: 'k'})); setTimeout(() => { const inp = document.getElementById('palette-input'); if(inp) { inp.value = '${q}'; inp.dispatchEvent(new Event('input')); }}, 100)`}
                class="hover:text-indigo-400 transition-colors"
              >
                {q}
              </button>
          ))}
      </div>
    </div>

    <!-- Knowledge Mesh Integration (Upper Area) -->
    <section class="mb-10">
      <MeshVisualizer />
    </section>
</div>

<script>
  // Unified Phase 2 Trigger: Direct input syncs to Command Palette
  document.addEventListener('astro:page-load', () => {
    const homeInput = document.getElementById('home-direct-input') as HTMLInputElement;
    const paletteInput = document.getElementById('palette-input') as HTMLInputElement;

    if (homeInput) {
        const syncAndOpen = (e: Event) => {
            const val = homeInput.value;
            document.dispatchEvent(new KeyboardEvent('keydown', { ctrlKey: true, key: 'k' }));
            
            // Wait for modal to mount
            setTimeout(() => {
                const pInput = document.getElementById('palette-input') as HTMLInputElement;
                if (pInput) {
                    pInput.value = val;
                    pInput.focus();
                    pInput.setSelectionRange(val.length, val.length);
                    pInput.dispatchEvent(new Event('input', { bubbles: true }));
                    // Use a slightly longer delay to clear home input after transfer is confirmed
                    setTimeout(() => { homeInput.value = ''; }, 10);
                }
            }, 100);
        };

        homeInput.addEventListener('focus', syncAndOpen);
        homeInput.addEventListener('click', syncAndOpen);
        homeInput.addEventListener('input', (e) => {
            if (homeInput.value.length > 0) syncAndOpen(e);
        });
        homeInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                syncAndOpen(e);
            }
        });
    }
  });
</script>

<style>
  .technical-header-container {
    animation: fade-in-up 0.6s ease-out;
  }
  
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
