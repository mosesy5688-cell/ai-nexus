---
// src/components/home/HomeSearch.astro
// V14.5: Refactored for CES Art 5.1 compliance - search logic extracted to home-search.js
import CategoryPills from './CategoryPills.astro';

interface Props {
  initialQuery?: string;
}

const { initialQuery = '' } = Astro.props;
---
<div class="mb-6 flex flex-col md:flex-row gap-4 items-center sticky top-[57px] bg-white/80 dark:bg-gray-900/80 backdrop-blur-sm py-3 z-30 max-w-4xl mx-auto w-full">
    <div id="search-container" class="w-full relative">
        <form id="search-form" action="/search" method="get" data-astro-reload class="w-full">
            <div class="relative">
                <input
                    type="search"
                    id="search-box"
                    name="q"
                    placeholder="Search any model… e.g., llama, embedding, image generation"
                    class="w-full p-3.5 pl-11 text-base tracking-tight border border-gray-300 dark:border-gray-600 rounded-sm bg-white dark:bg-gray-800 placeholder-gray-500 dark:placeholder-gray-400 text-gray-900 dark:text-white focus:ring-1 focus:ring-blue-500 focus:border-blue-500 shadow-none"
                    aria-label="Search AI Models"
                    value={initialQuery}
                />
                <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                    <svg class="w-6 h-6 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </div>
            </div>
        </form>
        <!-- Dropdown for instant results -->
        <div id="search-results-dropdown" class="absolute z-50 w-full mt-2 bg-white dark:bg-gray-800 rounded-sm shadow-sm border border-gray-200 dark:border-gray-700 max-h-96 overflow-y-auto hidden"></div>
        <!-- Search Hints -->
        <div class="mt-2.5 flex flex-wrap justify-center gap-2 text-[11px] font-bold text-gray-500 dark:text-gray-400">
            <span class="pt-0.5">Try:</span>
            <button type="button" class="search-hint px-2 py-0.5 bg-gray-100 dark:bg-gray-800 rounded-sm hover:bg-indigo-100 dark:hover:bg-zinc-700 text-gray-700 dark:text-gray-400 dark:hover:text-white uppercase tracking-widest border border-gray-200 dark:border-gray-700 transition-colors" data-query="llama 70b">llama 70b</button>
            <button type="button" class="search-hint px-2 py-0.5 bg-gray-100 dark:bg-gray-800 rounded-sm hover:bg-indigo-100 dark:hover:bg-zinc-700 text-gray-700 dark:text-gray-400 dark:hover:text-white uppercase tracking-widest border border-gray-200 dark:border-gray-700 transition-colors" data-query="code generation">code generation</button>
            <button type="button" class="search-hint px-2 py-0.5 bg-gray-100 dark:bg-gray-800 rounded-sm hover:bg-indigo-100 dark:hover:bg-zinc-700 text-gray-700 dark:text-gray-400 dark:hover:text-white uppercase tracking-widest border border-gray-200 dark:border-gray-700 transition-colors" data-query="embedding">embedding</button>
        </div>
        <!-- V14.2: Category Filter Pills -->
        <CategoryPills />
    </div>
</div>

<script>
  import { setupSearchEvents } from '../../scripts/home-search-events.js';
  document.addEventListener('DOMContentLoaded', setupSearchEvents);
</script>
