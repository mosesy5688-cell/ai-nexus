---
// src/components/home/HomeSearch.astro
// V14.5: Refactored for CES Art 5.1 compliance - search logic extracted to home-search.js
import CategoryPills from './CategoryPills.astro';

interface Props {
  initialQuery?: string;
}

const { initialQuery = '' } = Astro.props;
---
<div class="mb-12 max-w-2xl mx-auto w-full group">
    <div id="home-search-trigger" class="relative cursor-text border border-white/10 hover:border-white/20 bg-white/5 backdrop-blur-md rounded-lg p-4 transition-all flex items-center gap-4 group-hover:bg-white/10">
        <svg class="w-6 h-6 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
        <div class="flex-1 text-lg text-white/40 font-light select-none">
            Search 50,000+ entities instantly...
        </div>
        <div class="flex items-center gap-1.5 px-2 py-1 rounded bg-black/40 border border-white/10 text-[10px] text-white/40 font-mono tracking-tighter">
            <span>PRESS</span>
            <kbd class="text-white/60">CTRL K</kbd>
        </div>
    </div>
    
    <!-- V22.9: Rapid Category Shortcuts -->
    <div class="mt-6 flex flex-wrap justify-center gap-2">
        {['Models', 'Datasets', 'Agents', 'Tools', 'Papers'].map(cat => (
            <button 
                onclick={`document.dispatchEvent(new KeyboardEvent('keydown', {ctrlKey: true, key: 'k'})); setTimeout(() => { const inp = document.getElementById('palette-input'); if(inp) { inp.value = '${cat.toLowerCase()} '; inp.dispatchEvent(new Event('input')); }}, 100)`}
                class="px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-white/30 border border-white/5 hover:border-white/20 hover:text-white/60 transition-all rounded"
            >
                {cat}
            </button>
        ))}
    </div>
</div>

<script>
  // Unified Phase 2 Trigger: Clicking the home search bar opens the Command Palette
  document.getElementById('home-search-trigger')?.addEventListener('click', () => {
    document.dispatchEvent(new KeyboardEvent('keydown', { ctrlKey: true, key: 'k' }));
  });
</script>

<script>
  import { setupSearchEvents } from '../../scripts/home-search-events.js';
  document.addEventListener('DOMContentLoaded', setupSearchEvents);
</script>
