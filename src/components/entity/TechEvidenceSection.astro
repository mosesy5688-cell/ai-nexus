---
import BenchmarkCard from '../benchmark/BenchmarkCard.astro';
import MiniTrendChart from '../charts/MiniTrendChart.astro';

interface Props {
  entityId: string;
  entityName: string;
  entity: any;
  hasBench: boolean;
  enrichedTags: any[];
}

const { entityId, entityName, entity, hasBench, enrichedTags } = Astro.props;
---

<div class="tech-evidence-section grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
   {/* Column 1: Verification & Benchmarks */}
   <div class="space-y-8">
      {hasBench && (
        <div class="benchmark-zone animate-slide-up">
          <div class="flex items-center gap-2 mb-3 px-2">
            <span class="text-indigo-500 font-black">⚖️</span>
            <h3 class="text-[10px] font-black text-zinc-500 uppercase tracking-widest">Verified Benchmarks</h3>
          </div>
          <BenchmarkCard 
            umid={entityId}
            name={entityName}
            mmlu={entity?.mmlu}
            humaneval={entity?.humaneval}
            hellaswag={entity?.hellaswag}
            arc_challenge={entity?.arc_challenge}
            gsm8k={entity?.gsm8k}
            truthfulqa={entity?.truthfulqa}
            winogrande={entity?.winogrande}
            avg_score={entity?.avg_score}
            scores={entity?.benchmarks || entity?.meta_json?.benchmarks}
          />
        </div>
      )}

      {/* V16.96: Academic SOTA & Lineage Extra */}
      {(entity.pwc_sota_count > 0 || entity.pwc_benchmarks?.length > 0) && (
        <div class="px-5 py-4 bg-teal-900/10 rounded-sm border border-teal-800/20 animate-slide-up" style="animation-delay: 0.15s;">
           <div class="flex items-center gap-2 mb-2">
              <span class="text-teal-400">🏆</span>
              <span class="text-[10px] font-black text-teal-300 uppercase tracking-widest">SOTA Rank 1</span>
           </div>
           <div class="text-2xl font-black text-white leading-none mb-1">
              {entity.pwc_sota_count} Benchmarks
           </div>
           <div class="text-[10px] text-teal-400 font-bold uppercase tracking-tight">Verified via Papers With Code</div>
        </div>
      )}
   </div>

   {/* Column 2: Momentum & Context */}
   <div class="space-y-8">
      {(() => {
        const trendData = Array.isArray(entity?.trend_7d) ? entity.trend_7d.map(Number) : 
                          (typeof entity?.trend_7d === 'string' ? entity.trend_7d.split(',').map(Number) : 
                          (Array.isArray(entity?.fni_trend_7d) ? entity.fni_trend_7d.map(Number) : 
                          (typeof entity?.fni_trend_7d === 'string' ? entity.fni_trend_7d.split(',').map(Number) : [])));
        
        // V25.1: Only render Trend if it has meaningful variance (not flat lines)
        const hasVariance = trendData.length >= 2 && Math.max(...trendData) !== Math.min(...trendData);
        
        if (!hasVariance) return null;

        return (
          <div class="trend-zone p-5 bg-[var(--bg-surface)] rounded-sm border border-[var(--border-hairline)] animate-slide-up" style="animation-delay: 0.1s;">
             <div class="flex items-center gap-3 mb-4 pb-2 border-b border-[var(--border-hairline)]">
                <span class="text-xl">📈</span>
                <h3 class="text-[10px] font-black text-zinc-500 uppercase tracking-widest">Momentum Index</h3>
             </div>
             <div class="relative min-h-[140px] flex items-center justify-center">
                <MiniTrendChart 
                   entityId={entityId} 
                   width={380} 
                   height={140} 
                   initialData={trendData}
                />
             </div>
             <div class="mt-4 pt-4 border-t border-[var(--border-hairline)] flex justify-between items-center">
                <span class="text-[8px] font-black text-zinc-400 uppercase">7-Day FNI Velocity</span>
                <span class="text-[8px] font-black text-indigo-500 uppercase tracking-tighter">Real-time Feed</span>
             </div>
          </div>
        );
      })()}
   </div>
</div>
