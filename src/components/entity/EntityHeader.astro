---
/**
 * EntityHeader - V22.10 Industrial Hero Component
 * Replaces type-specific headers. Optimized for high-density data.
 */
import ShareButtons from '../common/ShareButtons.astro';
import EntityMetricGrid from './EntityMetricGrid.astro';
import { formatRelativeTime } from '../../utils/date-formatter.ts';

interface Props {
  name: string;
  author: string;
  entityType?: 'model' | 'agent' | 'dataset' | 'paper' | 'space' | 'tool';
  entityIcon?: string;
  entityLabel?: string;
  verified?: boolean;
  lastUpdated?: string;
  description?: string;
  fniScore?: number;
  fniPercentile?: number;
  fniCommentary?: string;
  fniP?: number;
  fniV?: number;
  fniC?: number;
  fniU?: number;
  fniPillarsSynthesized?: boolean;
  paramsB?: number;
  sourceUrl?: string;
  entityId?: string;
  hasImage?: boolean;
  trend_7d?: number[];
  contextLength?: number;
  downloads?: number;
  stars?: number;
}

const {
  name,
  author = '',
  entityType = 'model',
  entityIcon = '📦',
  entityLabel = 'Entity',
  verified = false,
  lastUpdated,
  description,
  fniScore = 0,
  fniPercentile = 0,
  fniP = 0,
  fniV = 0,
  fniC = 0,
  fniU = 0,
  fniPillarsSynthesized = false,
  paramsB,
  sourceUrl,
  entityId = '',
  hasImage = false,
  trend_7d: rawTrend = [],
  contextLength,
  downloads,
  stars
} = Astro.props;

const trend_7d = rawTrend || [];

// High-Density Sparkline Generator (Server-Side SVG)
function generateSvgPath(scores: number[], width: number, height: number, pad: number) {
  if (!scores || scores.length < 2) return "";
  const max = Math.max(...scores);
  const min = Math.min(...scores);
  const range = (max - min) || 1;
  const len = scores.length;
  
  return scores.map((s, i) => {
    const x = pad + (i / (len - 1)) * (width - pad * 2);
    const y = height - pad - ((s - min) / range) * (height - pad * 2);
    return `${i === 0 ? 'M' : 'L'} ${x.toFixed(2)} ${y.toFixed(2)}`;
  }).join(' ');
}

const firstScore = trend_7d[0] || 0;
const lastScore = trend_7d[trend_7d.length - 1] || 0;
const trendDiff = lastScore - firstScore;
const trendPercent = firstScore !== 0 ? ((trendDiff / firstScore) * 100).toFixed(1) : "0.0";
const trendDir = trendDiff > 0.05 ? 'up' : trendDiff < -0.05 ? 'down' : 'stable';
const trendColor = trendDir === 'up' ? 'text-green-500' : trendDir === 'down' ? 'text-red-500' : 'text-zinc-400';

const svgPath = generateSvgPath(trend_7d, 80, 32, 4);

// Type-specific colors (V22.10 Industrial Muted)
const typeColors: Record<string, string> = {
  model: 'text-zinc-400 border-zinc-500/20',
  agent: 'text-zinc-400 border-zinc-500/20',
  dataset: 'text-zinc-400 border-zinc-500/20',
  paper: 'text-zinc-400 border-zinc-500/20',
  space: 'text-zinc-400 border-zinc-500/20',
  tool: 'text-zinc-400 border-zinc-500/20',
};

const colors = typeColors[entityType] || typeColors.model;
const displayAuthor = (author && author !== 'Unknown' && author !== '') ? author : 'Independent / Community';
const relativeTime = formatRelativeTime(lastUpdated);
---

<header class="mb-8 border-b border-white/5 pb-8">
  <div class="flex flex-col gap-8">
    <!-- Identity Block -->
    <div class="flex items-start gap-4">
      <div class="flex flex-shrink-0 w-14 h-14 items-center justify-center bg-white/5 rounded-sm border border-white/10 text-2xl select-none font-mono">
        {entityIcon}
      </div>
      
      <div class="min-w-0 flex-1">
        <div class="flex items-center gap-3 mb-4">
          <span class={`px-2 py-0.5 rounded text-[10px] font-black uppercase tracking-widest border ${colors}`}>
            {entityLabel}
          </span>
          {relativeTime && (
            <span class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">
              {relativeTime}
            </span>
          )}
        </div>
        
        <h1 class="text-2xl sm:text-4xl font-black text-white tracking-tighter leading-none mb-3 uppercase">
          {name}
        </h1>
        
        <div class="flex flex-wrap items-center gap-6 text-sm font-medium text-zinc-500">
          <span class="flex items-center gap-2">
            by <strong class="text-white font-bold">{displayAuthor}</strong>
          </span>
          {entityId && (
            <span class="font-mono text-xs text-zinc-500 opacity-80 truncate max-w-[350px]" title={entityId}>
              {entityId}
            </span>
          )}
        </div>
      </div>
    </div>

    <!-- V22.11 Industrial Metric Grid (Extracted) -->
    <EntityMetricGrid 
      fniScore={fniScore}
      fniPercentile={fniPercentile}
      fniP={fniP}
      fniV={fniV}
      fniC={fniC}
      fniU={fniU}
      fniPillarsSynthesized={fniPillarsSynthesized}
      paramsB={paramsB}
      contextLength={contextLength}
      downloads={downloads}
      svgPath={svgPath}
      trendColor={trendColor}
      trendPercent={trendPercent}
    />
  </div>

  {description && (
    <div class="mt-5 max-w-5xl">
      <p class="text-[13px] text-zinc-400 leading-snug font-medium tracking-tight">
        {description}
      </p>
    </div>
  )}

  <div class="mt-8 flex items-center justify-between pt-8 border-t border-white/5">
    <div class="flex items-center gap-4">
      {sourceUrl && (
        <a href={sourceUrl} target="_blank" class="px-5 py-2 bg-white text-black rounded font-bold text-xs hover:bg-zinc-200 transition-colors flex items-center gap-2">
          Source <span>→</span>
        </a>
      )}
    </div>
    <ShareButtons title={name} description={description || ''} />
  </div>
</header>
